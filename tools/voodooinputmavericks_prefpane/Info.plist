<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleIdentifier</key>
	<string>com.schmonz.VoodooInputMavericksPane</string>
	<key>CFBundleName</key>
	<string>VoodooInputMavericksPane</string>
	<key>CFBundleExecutable</key>
	<string>VoodooInputMavericksPane</string>
	<key>CFBundlePackageType</key>
	<string>osax</string>
	<key>CFBundleVersion</key>
	<string>1.0</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<!-- Scripting Addition handler map: the 8-char key is event class 'MT2x' +
	     event id 'load'. Context Process = run in the host app (System Prefs). -->
	<key>OSAXHandlers</key>
	<dict>
		<key>Events</key>
		<dict>
			<key>MT2xload</key>
			<dict>
				<key>Handler</key>
				<string>MT2InjectHandler</string>
				<key>Context</key>
				<string>Process</string>
				<key>ThreadSafe</key>
				<false/>
			</dict>
		</dict>
	</dict>
</dict>
</plist>
