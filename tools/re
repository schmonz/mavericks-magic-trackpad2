sub_objc_methods() {  # <target> [filter] | <target> --at <addr-hex>
  bin=$(re_resolve "$1")
  [ -n "$1" ] || { echo "usage: $me objc-methods <target> [filter] | <target> --at <addr-hex>" >&2; return 2; }
  shift
  at=""
  if [ "$1" = "--at" ]; then at=$(printf '%s' "$2" | sed 's/^0[xX]//' | tr 'A-F' 'a-f'); fi
  filter=$1
  # ObjC runtime metadata carries selector -> IMP. Two on-disk shapes:
  #  - STRIPPED (kexts, prefpanes): `otool -oV` prints the imp as a raw `0x..` address,
  #    and we reconstruct the [Class sel] label from the CLASS/METACLASS + name markers.
  #  - NON-STRIPPED (system frameworks, e.g. IOBluetoothUI): `otool -oV` SYMBOLICATES the
  #    imp as `-[Class sel]` (no address) — so we take the address from `otool -o` (raw),
  #    paired by imp-line order, and use the imp line's own label.
  # Unified: slurp raw imp addresses from `otool -o` (in order) and index them by imp #.
  if re_dyld_backend "$bin"; then
    # dyld_info -objc refuses on cache dylibs ("cannot print live objc info"),
    # but the disassembler labels every IMP as +[Class sel]: / -[Class sel]: —
    # the imp address is that method's first instruction.
    parse() {
      re_otool "$bin" | awk '
        /^[+-]\[.*\]:$/ { lbl=$0; sub(/:$/,"",lbl); pend=lbl; next }
        pend!="" && $1 ~ /^[0-9a-f]{5,16}$/ { printf "0x%s\t%s\n", $1, pend; pend="" }'
    }
  else
  parse() {
    otool -oV -arch "$arch" "$bin" 2>/dev/null | awk -v arch="$arch" -v bin="$bin" '
      BEGIN {
        cmd = "otool -o -arch " arch " \"" bin "\" 2>/dev/null"
        while ((cmd | getline l) > 0) {
          if (l ~ /^[ \t]*imp[ \t]+0x/) { sub(/^[ \t]*imp[ \t]+/,"",l); sub(/[ \t].*$/,"",l); A[++na]=l }
        }
        close(cmd); i=0
      }
      /_OBJC_METACLASS_\$_/ { c=$0; sub(/.*_OBJC_METACLASS_\$_/,"",c); sub(/[ \t].*/,"",c); cls=c; kind="+"; next }
      /_OBJC_CLASS_\$_/     { c=$0; sub(/.*_OBJC_CLASS_\$_/,"",c);     sub(/[ \t].*/,"",c); cls=c; kind="-"; next }
      $1=="name"  { s=$0; sub(/^[ \t]*name[ \t]+0x[0-9a-f]+[ \t]*/,"",s); pend=s; next }
      $1=="types" { meth=pend; next }
      $1=="imp"   {
        i++                                    # count EVERY imp line to stay aligned with A[] (from -o)
        if (meth!="") {
          addr = (i in A) ? A[i] : $2          # raw address by order; fall back to a stripped 0x imp
          printf "%s\t%s[%s %s]\n", addr, kind, cls, meth   # reconstructed label = correct +/- (meta vs class)
          meth=""
        }
      }'
  }
  fi
  if [ -n "$at" ]; then
    echo "# ObjC method containing 0x$at in $bin ($arch)"
    parse | awk -v a="$at" '
      function h2i(x,  n,i,c){ sub(/^0x/,"",x); x=tolower(x); n=0; for(i=1;i<=length(x);i++){c=index("0123456789abcdef",substr(x,i,1))-1; n=n*16+c} return n }
      { ia=h2i($1); aa=h2i(a); if (ia<=aa && ia>best) { best=ia; line=$0 } }
      END { if (line!="") printf "%s   (+0x%x into the method)\n", line, aa-best; else print "# (no method at/before 0x" a ")" }'
  else
    echo "# ObjC methods in $bin ($arch)${filter:+   (filter: $filter)}"
    echo "# columns: imp-address  -[Class selector]"
    if [ -n "$filter" ]; then parse | sort | grep -iE "$filter"; else parse | sort; fi
  fi
}

# --- dispatch ----------------------------------------------------------------
# When sourced as a library (RE_LIB=1), stop here so the helpers above can be
# unit-tested without running a subcommand.
[ "${RE_LIB:-}" = 1 ] && return 0 2>/dev/null

cmd=$1; [ $# -gt 0 ] && shift
case "$cmd" in
  disasm)        sub_disasm "$@" ;;
  syms)          sub_syms "$@" ;;
  objc-methods)  sub_objc_methods "$@" ;;
  calls)         sub_calls "$@" ;;
  str-xref)      sub_str_xref "$@" ;;
  xref)          sub_xref "$@" ;;
  xref-offset)   sub_xref_offset "$@" ;;
  vtable)        sub_vtable "$@" ;;
  strings)       sub_strings "$@" ;;
  consts)        sub_consts "$@" ;;
  hex)           sub_hex "$@" ;;
  bcmp)          sub_bcmp "$@" ;;
  plist)         sub_plist "$@" ;;
  amd-actuation) sub_amd_actuation "$@" ;;
  conn-trace)    sub_conn_trace "$@" ;;
  bt-timeline)   sub_bt_timeline "$@" ;;
  ioreg-class)   sub_ioreg_class "$@" ;;
  ioreg-props)   sub_ioreg_props "$@" ;;
  klog)          sub_klog "$@" ;;
  kexts)         sub_kexts "$@" ;;
  mt-contacts)   sub_mt_contacts "$@" ;;
  mt-devices)    sub_mt_devices "$@" ;;
  mt2-name)      sub_mt2_name "$@" ;;
  help|-h|--help|"") usage 0 ;;
  *) echo "$me: unknown subcommand '$cmd'  (try '$me help')" >&2; exit 2 ;;
esac
