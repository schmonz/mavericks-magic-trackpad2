#!/bin/sh
# re - one reverse-engineering toolkit with subcommands. Unix-filter style, readable,
# allowlist-friendly (ONE entry covers every subcommand). Replaces the former re/* scripts.
#
#   re <subcommand> [args...]      re help     re <subcommand> --help
#
# STATIC BINARY (Mach-O):                      LIVE SYSTEM / DOMAIN ORACLES:
#   disasm   function/range machine code         ioreg-class   class presence + count
#   syms     symbols by name                      ioreg-props   class node(s) + properties
#   objc-methods ObjC selector -> IMP (meta)      kexts         loaded kexts (kextstat)
#   calls    who calls an addr or symbol          klog          kernel log (system.log)
#   str-xref string ref -> enclosing function     amd-actuation cursor-wiring verdict
#   xref     who references an abs addr (arm64)
#   xref-offset struct-field accesses             conn-trace    BT connect timeline verdict
#                                                    bt-timeline   BT connect activity, all layers
#   vtable   slot offset <-> method               mt-contacts   stream recognizer contacts
#   strings  printable strings                     mt-devices    MultitouchSupport device list
#                                                    mt2-name      READ on-device HID DeviceName reports
#   consts   dump a Mach-O section
#   hex      hex+ASCII dump of a file
#   bcmp     compare a byte window of two files
#   plist    read a kext/bundle Info.plist
#
# Targets accept a path OR a short alias. Arch defaults x86_64 (RE_ARCH=i386 overrides).

# Default arch follows the host: Mavericks/Intel target -> x86_64; modern Apple
# Silicon -> arm64e. RE_ARCH overrides (e.g. RE_ARCH=i386). This is what lets the
# same subcommands operate on either platform.
case "$(uname -m 2>/dev/null)" in
  arm64) arch_default=arm64e ;;
  *)     arch_default=x86_64 ;;
esac
arch=${RE_ARCH:-$arch_default}
me="re"

# Cache-derived text carries non-UTF8 bytes; treat everything as raw bytes so awk
# doesn't emit "towc: multibyte conversion failure" and truncate. (No effect on the
# ASCII-only output the Mavericks pipeline produces.)
export LC_ALL=C

# --- shared resolvers --------------------------------------------------------
# Mach-O binary by alias-or-path (union of every tool's alias map).
re_resolve() {
  case "$1" in
    MultitouchHID)            echo "/System/Library/Extensions/AppleMultitouchDriver.kext/Contents/PlugIns/MultitouchHID.plugin/Contents/MacOS/MultitouchHID" ;;
    MultitouchSupport)        echo "/System/Library/PrivateFrameworks/MultitouchSupport.framework/Versions/A/MultitouchSupport" ;;
    AppleBluetoothMultitouch) echo "/System/Library/Extensions/AppleBluetoothMultitouch.kext/Contents/MacOS/AppleBluetoothMultitouch" ;;
    AppleMultitouchDriver)    echo "/System/Library/Extensions/AppleMultitouchDriver.kext/Contents/MacOS/AppleMultitouchDriver" ;;
    AppleUSBMultitouch)       echo "/System/Library/Extensions/AppleUSBMultitouch.kext/Contents/MacOS/AppleUSBMultitouch" ;;
    IOBluetoothHIDDriver)     echo "/System/Library/Extensions/IOBluetoothHIDDriver.kext/Contents/MacOS/IOBluetoothHIDDriver" ;;
    IOBluetoothFamily)        echo "/System/Library/Extensions/IOBluetoothFamily.kext/Contents/MacOS/IOBluetoothFamily" ;;
    IOBluetoothUI)            echo "/System/Library/Frameworks/IOBluetoothUI.framework/Versions/A/IOBluetoothUI" ;;
    IOBluetooth)              echo "/System/Library/Frameworks/IOBluetooth.framework/Versions/A/IOBluetooth" ;;
    BluetoothManager)         echo "/System/Library/PrivateFrameworks/BluetoothManager.framework/Versions/A/BluetoothManager" ;;
    BluetoothServices)        echo "/System/Library/PrivateFrameworks/BluetoothServices.framework/Versions/A/BluetoothServices" ;;
    blued)                    echo "/usr/sbin/blued" ;;
    bluetoothd)               echo "/usr/sbin/bluetoothd" ;;
    IOHIDFamily)              echo "/System/Library/Extensions/IOHIDFamily.kext/Contents/MacOS/IOHIDFamily" ;;
    Trackpad)                 echo "/System/Library/PreferencePanes/Trackpad.prefPane/Contents/MacOS/Trackpad" ;;
    Mouse)                    echo "/System/Library/PreferencePanes/Mouse.prefPane/Contents/MacOS/Mouse" ;;
    *)                        echo "$1" ;;
  esac
}
# Info.plist by alias-or-bundle/plist-path.
re_resolve_plist() {
  case "$1" in
    MultitouchHID)            echo "/System/Library/Extensions/AppleMultitouchDriver.kext/Contents/PlugIns/MultitouchHID.plugin/Contents/Info.plist" ;;
    MultitouchSupport)        echo "/System/Library/PrivateFrameworks/MultitouchSupport.framework/Resources/Info.plist" ;;
    AppleBluetoothMultitouch) echo "/System/Library/Extensions/AppleBluetoothMultitouch.kext/Contents/Info.plist" ;;
    AppleUSBMultitouch)       echo "/System/Library/Extensions/AppleUSBMultitouch.kext/Contents/Info.plist" ;;
    AppleMultitouchDriver)    echo "/System/Library/Extensions/AppleMultitouchDriver.kext/Contents/Info.plist" ;;
    IOBluetoothHIDDriver)     echo "/System/Library/Extensions/IOBluetoothHIDDriver.kext/Contents/Info.plist" ;;
    IOBluetoothFamily)        echo "/System/Library/Extensions/IOBluetoothFamily.kext/Contents/Info.plist" ;;
    IOHIDFamily)              echo "/System/Library/Extensions/IOHIDFamily.kext/Contents/Info.plist" ;;
    *.plist)                  echo "$1" ;;
    *.kext|*.plugin|*.framework|*.app)  echo "$1/Contents/Info.plist" ;;
    *)                        [ -d "$1" ] && echo "$1/Contents/Info.plist" || echo "$1" ;;
  esac
}

# Normalize a hex (0x..) or decimal number to decimal; empty/absent -> 0.
re_hexnum() { case "$1" in 0x*|0X*) printf '%d' "$1" ;; *) printf '%d' "${1:-0}" ;; esac; }

# --- platform backend --------------------------------------------------------
# A resolved target that isn't a real on-disk file lives in the dyld shared cache
# (modern macOS). There, classic otool/nm/strings can't open it; dyld_info reads
# it. These helpers emit the SAME normalized shapes the awk pipelines expect, so
# every subcommand behaves identically on Mavericks (on-disk) and here (cache).
re_cache_only() { [ ! -e "$1" ]; }

# Which backend for CODE-level ops (disasm / objc-methods / calls / str-xref)?
# The dyld_info backend is required for the shared cache AND for any arm64 target
# even on disk — classic otool can't disassemble arm64 (it shells to otool-classic).
# nm/strings/otool -s still read on-disk files of any arch fine, so syms/strings/
# consts keep using re_cache_only; only the disassembler-backed ops use this.
re_dyld_backend() { case "$arch" in arm64*) return 0 ;; esac; re_cache_only "$1"; }

# dyld_info -disassemble -> otool -tV shape: "<lowerhexaddr>\t<instr>" + "label:".
re_disasm_norm() {
  awk '
    /^\// { next }                              # "/path [arch]:" header
    /^\(__/ { next }                            # "(__TEXT,__text) section:"
    /^0x[0-9A-Fa-f]+[ \t]/ {                    # instruction line
      addr=$1; sub(/^0x/,"",addr)
      instr=$0; sub(/^0x[0-9A-Fa-f]+[ \t]+/,"",instr); sub(/[ \t]+$/,"",instr)
      printf "%s\t%s\n", tolower(addr), instr; next
    }
    /:[ \t]*$/ { lbl=$0; sub(/[ \t]*$/,"",lbl); print lbl }   # _sym:  or  +[Class sel]:
  '
}

# Disassembly text for a Mach-O (vmaddr space), demangled. The shared pipeline
# behind disasm/calls/str-xref/xref-offset. On-disk -> otool; cache -> dyld_info.
re_otool() {
  if re_dyld_backend "$1"; then
    # Disassembling a whole framework out of the cache is slow; memoize the
    # normalized dump so repeated disasm/calls/str-xref/objc-methods reuse it.
    _cf="${TMPDIR:-/tmp}/re-disasm-$(printf '%s' "$1$arch" | tr -c 'A-Za-z0-9' _).txt"
    [ -s "$_cf" ] || dyld_info "$1" -arch "$arch" -disassemble 2>/dev/null | re_disasm_norm > "$_cf"
    c++filt < "$_cf"
  else
    otool -tV -arch "$arch" "$1" 2>/dev/null | c++filt
  fi
}

# Symbol table, nm -n shape: "<hexaddr> <kind> <name>". Cache exposes only the
# export trie (addresses are cache offsets, fine for name lookup / existence).
re_syms_src() {
  if re_cache_only "$1"; then
    dyld_info "$1" -arch "$arch" -exports 2>/dev/null | awk '
      /^[ \t]*0x[0-9A-Fa-f]+[ \t]/ { a=$1; sub(/^0x/,"",a); printf "%s T %s\n", tolower(a), $2 }'
  else
    nm -n -arch "$arch" "$1" 2>/dev/null
  fi
}

# Printable strings, `strings -t x` shape: "<hexoff> <text>". Cache: union the
# literal sections (cstring + objc selector/class names) via dyld_info -section.
re_strings_src() {
  _b=$1; _min=${2:-4}
  # Use dyld_info for any arm64 target (not just cache) so offsets are VMADDRs,
  # consistent with disasm/syms/xref — classic `strings -t x` prints FILE offsets,
  # which don't line up with the vmaddr space the disassembler works in.
  if re_dyld_backend "$_b"; then
    for _sect in "__TEXT __cstring" "__TEXT __objc_methname" "__TEXT __objc_classname" "__TEXT __oslogstring" "__TEXT __os_log"; do
      dyld_info "$_b" -arch "$arch" -section $_sect 2>/dev/null
    done | awk -v min="$_min" '
      /^0x[0-9A-Fa-f]+[ \t]/ {
        a=$1; sub(/^0x/,"",a)
        s=$0; sub(/^0x[0-9A-Fa-f]+[ \t]+/,"",s); sub(/^"/,"",s); sub(/"[ \t]*$/,"",s)
        if (length(s) >= min) printf "%s %s\n", tolower(a), s
      }'
  else
    strings -a -t x -n "$_min" "$_b" 2>/dev/null
  fi
}

# Name of the text symbol defined at exactly <addr> (hex, any form), or empty.
re_sym_at_addr() {
  _bin=$1; _a=$(printf '%s' "$2" | sed 's/^0[xX]//' | tr 'A-F' 'a-f')
  nm -n -arch "$arch" "$_bin" 2>/dev/null | awk -v a="$_a" '
    function h2i(x,  n,i,c){ n=0; x=tolower(x); for(i=1;i<=length(x);i++){c=index("0123456789abcdef",substr(x,i,1))-1; n=n*16+c} return n }
    ($2=="T"||$2=="t") && h2i($1)==h2i(a) { print $3; exit }'
}

usage() {
  sed -n '2,21p' "$0" | sed 's/^# \{0,1\}//'
  exit "${1:-0}"
}

# --- subcommands -------------------------------------------------------------

sub_disasm() {  # <target> "<fn>" ["filter"] | <start-hex> [end-hex] ["filter"]
  bin=$(re_resolve "$1"); want=$2
  [ -n "$bin" ] && [ -n "$want" ] || { echo "usage: $me disasm <target> \"<function>\" [\"filter\"] | <start-hex> [end-hex] [\"filter\"]" >&2; return 2; }
  pad() { printf '%016x' "0x${1#0x}"; }
  sig=""; filter=""
  # dyld_info backend + function-name: no nm ranges available, so slice the
  # normalized disasm between its own labels. (Raw-range form flows through re_otool.)
  if re_dyld_backend "$bin" && ! printf '%s' "$want" | grep -qiE '^(0x)?[0-9a-f]+$'; then
    echo "# binary:   $bin ($arch)   [dyld cache: sliced by label]"
    echo "# columns:  offset  address  instruction${3:+   (filtered: $3)}"
    re_otool "$bin" | awk -v q="$want" -v filt="$3" '
      function h2i(x,  n,i,c){ x=tolower(x); n=0; for(i=1;i<=length(x);i++){c=index("0123456789abcdef",substr(x,i,1))-1; n=n*16+c} return n }
      /:$/ && $1 !~ /^[0-9a-f]{5,16}$/ {
        lbl=$0; sub(/:$/,"",lbl)
        if (inb) exit
        if (index(tolower(lbl), tolower(q))>0) { inb=1; base=-1; print "# function: " lbl }
        next
      }
      inb && $1 ~ /^[0-9a-f]{5,16}$/ {
        a=h2i($1); if (base<0) base=a
        instr=$0; sub(/^[0-9a-f]+[ \t]+/,"",instr)
        if (filt=="" || tolower(instr) ~ tolower(filt)) printf "+0x%-5x 0x%x  %s\n", a-base, a, instr
      }'
    return
  fi
  if printf '%s' "$want" | grep -qiE '^(0x)?[0-9a-f]+$'; then
    start=$(pad "$want"); end=""; [ -n "$3" ] && end=$(pad "$3"); filter=$4; sig="(raw range)"
  else
    filter=$3
    hit=$(nm -n -arch "$arch" "$bin" 2>/dev/null | c++filt | awk -v q="$want" '
      $2=="T" || $2=="t" { n++; addr[n]=$1; line[n]=$0 }
      END { for (i=1;i<=n;i++) if (index(line[i],q)>0) {
              print addr[i]; print (i<n?addr[i+1]:""); print line[i]; exit } }')
    [ -n "$hit" ] || { echo "no function matching: $want" >&2; return 1; }
    start=$(pad "$(printf '%s\n' "$hit" | sed -n 1p)")
    eraw=$(printf '%s\n' "$hit" | sed -n 2p); end=""; [ -n "$eraw" ] && end=$(pad "$eraw")
    sig=$(printf '%s\n' "$hit" | sed -n 3p | sed -E 's/^[0-9a-f]+[[:space:]]+[A-Za-z][[:space:]]+//')
  fi
  si=$(printf '%d' "0x$start"); ei=""; [ -n "$end" ] && ei=$(printf '%d' "0x$end")
  echo "# function: $sig"
  echo "# binary:   $bin ($arch)   range 0x$(printf %x "$si")$([ -n "$ei" ] && printf '..0x%x' "$ei")"
  echo "# columns:  offset  address  instruction${filter:+   (filtered: $filter)}"
  emit() {
    re_otool "$bin" | awk -v si="$si" -v ei="$ei" -v max=400 '
      function h2i(x,  n,i,c){ sub(/^0x/,"",x); x=tolower(x); n=0
        for(i=1;i<=length(x);i++){ c=index("0123456789abcdef",substr(x,i,1))-1; n=n*16+c } return n }
      $1 ~ /^[0-9a-f]{5,16}$/ {
        a=h2i($1)
        if (a < si) next
        if (ei!="" && a >= ei) exit
        instr=$0; sub(/^[0-9a-f]+[ \t]+/,"",instr); gsub(/\t/," ",instr)
        printf "+0x%-5x 0x%x  %s\n", a-si, a, instr
        shown++; if (ei=="" && shown>=max) exit
      }'
  }
  if [ -n "$filter" ]; then emit | grep -iE "$filter"; else emit; fi
}

sub_syms() {  # <target> ["name filter"]
  bin=$(re_resolve "$1"); pat=${2:-.}
  [ -n "$1" ] || { echo "usage: $me syms <target> [\"name filter\"]" >&2; return 2; }
  echo "# symbols in $bin ($arch) matching: $pat"
  echo "# columns: address  kind  name"
  re_syms_src "$bin" | c++filt | awk -v q="$pat" '
    function kindword(k){
      if(k=="T"||k=="t") return "text"; if(k=="D"||k=="d") return "data"
      if(k=="B"||k=="b") return "bss";  if(k=="S"||k=="s") return "symbol"
      if(k=="C"||k=="c") return "const"; if(k=="U") return "undefined"
      if(k=="A") return "absolute"; return k }
    {
      if (NF>=3 && $1 ~ /^[0-9a-f]+$/) { addr="0x"$1; kind=kindword($2); sub(/^[0-9a-f]+[ \t]+[A-Za-z][ \t]+/,"") }
      else                            { addr="-";     kind=kindword($1); sub(/^[ \t]*[A-Za-z][ \t]+/,"") }
      if ($0=="") next
      if ($0 ~ q) printf "%s\t%s\t%s\n", addr, kind, $0
    }'
}

sub_calls() {  # <target> <addr-hex-or-symbol>
  bin=$(re_resolve "$1"); tgt=$2
  [ -n "$bin" ] && [ -n "$tgt" ] || { echo "usage: $me calls <target> <addr-hex-or-symbol>" >&2; return 2; }
  # Accept an address (resolve to its defining symbol) or a symbol name directly.
  # otool disassembles intra-binary calls as `callq _symbol`, NOT the numeric
  # target — so matching the name is what actually finds call sites on dylibs.
  if printf '%s' "$tgt" | grep -qiE '^(0x)?[0-9a-f]+$'; then
    addr=$(printf '%s' "$tgt" | sed 's/^0[xX]//' | tr 'A-F' 'a-f')
    name=$(re_sym_at_addr "$bin" "$addr")
  else
    addr=""; name=$tgt
  fi
  hdr=${name:-0x$addr}; [ -n "$name" ] && [ -n "$addr" ] && hdr="$name (0x$addr)"
  echo "# call sites targeting $hdr in $bin ($arch)  — enclosing function + the call line"
  re_otool "$bin" | awk -v a="$addr" -v nm="$name" '
    function bare(s){ sub(/^_+/,"",s); return s }
    function endswith(s,suf){ return length(suf)<=length(s) && substr(s,length(s)-length(suf)+1)==suf }
    # arm64 dispatches selectors through stubs: bl _objc_msgSend$selector (also
    # objc_msgSendSuper2$..., objc_alloc_init$...). Treat a query for "selector"
    # as matching the stub whose target ends with "$selector".
    function selmatch(t,q,  bt,bq){ bt=bare(t); bq=bare(q); return bt==bq || endswith(bt,"$" bq) }
    /:$/ && $1 !~ /^[0-9a-f]{5,16}/ { fn=$0; sub(/:$/,"",fn) }
    /[ \t](callq|bl|blr)[ \t]/ {                 # x86 callq  /  arm64 bl,blr
      t=$0; sub(/.*[ \t](callq|bl|blr)[ \t]+/,"",t); sub(/[ \t]*##.*/,"",t); sub(/[ \t]*;.*/,"",t); sub(/[ \t].*/,"",t); gsub(/"/,"",t)  # dyld_info quotes selector branch targets ("_objc_msgSend$foo:")
      if ((nm!="" && selmatch(t,nm)) || (a!="" && (t=="0x" a || index(t,a)>0))) {
        instr=$0; sub(/^[0-9a-f]+[ \t]+/,"",instr); gsub(/\t/," ",instr)
        printf "%s  in %s\n    %s\n", $1, (fn==""?"?":fn), instr
      }
    }'
}

sub_str_xref() {  # <target> "<substring>" [context-lines]
  bin=$(re_resolve "$1"); q=$2; ctx=${3:-8}
  [ -n "$2" ] || { echo "usage: $me str-xref <target> \"<substring>\" [context-lines]" >&2; return 2; }
  echo "# code referencing \"$q\" in $bin ($arch)  — enclosing function + window (ctx ${ctx}/3)"
  re_otool "$bin" | awk -v q="$q" -v ctx="$ctx" '
    /:$/ && $1 !~ /^[0-9a-f]{5,16}/ { fn=$0; sub(/:$/,"",fn) }
    { L[NR]=$0; F[NR]=fn }
    index($0,q)>0 { hit[++h]=NR }
    END {
      if (h==0) { print "# (no references found)"; exit 1 }
      for (j=1;j<=h;j++) {
        m=hit[j]; printf "=== %s ===\n", (F[m]==""?"?":F[m])
        lo=m-ctx; if (lo<1) lo=1
        for (i=lo;i<=m+3;i++) if (i in L) print L[i]
        print ""
      }
    }'
}

sub_xref() {  # <target> <addr-hex>   (arm64: who references an absolute address)
  bin=$(re_resolve "$1"); tgt=$2
  [ -n "$bin" ] && [ -n "$tgt" ] || { echo "usage: $me xref <target> <addr-hex>  (find code that forms/loads that address: adrp+add / adrp+ldr)" >&2; return 2; }
  case "$tgt" in 0x*|0X*) ;; *) tgt="0x$tgt" ;; esac
  echo "# code referencing address $tgt in $bin ($arch)  — arm64 adrp+add (address) / adrp+ldr (pointer slot)"
  echo "# columns: address  function  instruction"
  re_otool "$bin" | awk -v tgt="$tgt" '
    function h2i(x,  n,i,c){ sub(/^#/,"",x); sub(/^0x/,"",x); x=tolower(x); n=0
      for(i=1;i<=length(x);i++){c=index("0123456789abcdef",substr(x,i,1))-1; n=n*16+c} return n }
    function emit(a,f,i){ printf "0x%s  %s  %s\n", a, (f==""?"?":f), i }
    BEGIN{ T=h2i(tgt) }
    /:$/ && $1 !~ /^[0-9a-f]{5,16}$/ { fn=$0; sub(/:$/,"",fn); next }
    $1 ~ /^[0-9a-f]{5,16}$/ {
      addr=$1; instr=$0; sub(/^[0-9a-f]+[ \t]+/,"",instr); gsub(/\t/," ",instr)
      mnem=instr; sub(/[ \t].*/,"",mnem)
      if (mnem=="adrp") {                              # adrp reg, N   ; 0xPAGE
        reg=instr; sub(/^adrp[ \t]+/,"",reg); sub(/,.*/,"",reg)
        p=instr; if (sub(/.*;[ \t]*0x/,"",p)) { sub(/[^0-9a-fA-F].*/,"",p); PG[reg]=h2i("0x" p) }
        next
      }
      if (mnem=="add") {                               # add dst, src, #imm
        s=instr; sub(/^add[ \t]+/,"",s); split(s,f,/[ ,]+/)
        if (f[3] ~ /^#/ && (f[2] in PG) && PG[f[2]]+h2i(f[3])==T) emit(addr,fn,instr)
        next
      }
      if (mnem ~ /^ldr/) {                             # ldr dst, [src, #imm]  (GOT/pointer)
        if (match(instr, /\[[^]]*\]/)) {
          inside=substr(instr,RSTART+1,RLENGTH-2); gsub(/ /,"",inside)
          split(inside,g,","); if ((g[1] in PG) && PG[g[1]]+(g[2]?h2i(g[2]):0)==T) emit(addr,fn,instr)
        }
      }
    }'
}

sub_xref_offset() {  # <target> <offset-hex> [R|W]
  bin=$(re_resolve "$1"); off=$2; rwf=$3
  [ -n "$bin" ] && [ -n "$off" ] || { echo "usage: $me xref-offset <target> <offset-hex> [R|W]" >&2; return 2; }
  case "$off" in 0x*) ;; *) off="0x$off" ;; esac
  echo "# offset $off accesses in $bin ($arch)"
  echo "# columns: rw  address  function  instruction"
  re_otool "$bin" | awk -v off="$off" -v rwf="$rwf" '
    /:$/ && $1 !~ /^[0-9a-f]{5,16}\t?/ { fn=$0; sub(/:$/,"",fn); next }
    $1 ~ /^[0-9a-f]{5,16}$/ {
      addr=$1; instr=$0; sub(/^[0-9a-f]+[ \t]+/,"",instr); gsub(/\t/," ",instr)
      pat = off "(%"
      if (index(instr, pat)==0) next
      last=instr
      if (index(instr, ",")>0) { n=split(instr, p, ","); last=p[n] }
      else { sub(/^[^ ]+[ ]+/,"",last) }
      gsub(/^ +| +$/,"",last)
      rw = (index(last, pat)==1) ? "W" : "R"
      mnem=instr; sub(/[ \t].*/,"",mnem)
      if (mnem ~ /^(test|cmp|lea|push|bt)/) rw="R"   # these read/compute, never write the mem operand
      if (rwf!="" && toupper(rwf)!=rw) next
      sub(/^0+/,"",addr); if (addr=="") addr="0"
      printf "%s  0x%s  %s  %s\n", rw, addr, (fn==""?"?":fn), instr
    }'
}

sub_vtable() {  # <target> "<Class>" <hexoff>... | --find "<regex>"
  bin=$(re_resolve "$1"); cls=$2
  [ -n "$cls" ] && [ -n "$3" ] || { echo "usage: $me vtable <target> \"<ClassName>\" <hexoff> [hexoff...] | --find \"<regex>\"" >&2; return 2; }
  shift 2
  if re_cache_only "$bin"; then
    echo "# vtable: unsupported for dyld-cache targets ($bin) — needs on-disk Mach-O bytes." >&2
    echo "# (arm64/objc RE: use 'objc-methods' for selectors, 'disasm' to inspect an IMP.)" >&2
    return 2
  fi
  [ -f "$bin" ] || { echo "no such binary: $bin" >&2; return 2; }
  echo "# vtable for $cls in $bin ($arch)"
  VT_BIN="$bin" VT_ARCH="$arch" VT_CLS="$cls" python2.7 - "$@" <<'PY'
import os,sys,struct,subprocess
bin=os.environ["VT_BIN"]; arch=os.environ["VT_ARCH"]; cls=os.environ["VT_CLS"]
ns=subprocess.check_output(["nm","-arch",arch,bin]).splitlines()
filt=subprocess.Popen(["c++filt"],stdin=subprocess.PIPE,stdout=subprocess.PIPE)
demangled=filt.communicate("\n".join(l.split()[2] for l in ns if len(l.split())>=3))[0].splitlines()
rows=[l.split() for l in ns if len(l.split())>=3]
vt=None
for (p,d) in zip(rows,demangled):
    if d.strip()=="vtable for "+cls:
        vt=int(p[0],16); break
if vt is None:
    sys.stderr.write("vtable for %s not found\n"%cls); sys.exit(1)
print "# (vtable symbol @ 0x%x; object vptr = symbol+0x10)" % vt
o=subprocess.check_output(["otool","-arch",arch,"-l",bin]).splitlines()
segs=[];cur=None
for ln in o:
    s=ln.strip()
    if s.startswith("sectname"): cur={}
    elif s.startswith("addr ") and cur is not None: cur["addr"]=int(s.split()[1],16)
    elif s.startswith("offset ") and cur is not None: cur["off"]=int(s.split()[1]);segs.append(cur);cur=None
data=open(bin,"rb").read()
tsyms=sorted(((int(p[0],16),p[2]) for p in rows if p[1] in ("t","T")), key=lambda x:x[0])
import bisect
addrs=[a for a,_ in tsyms]
def name_at(ptr):
    i=bisect.bisect_right(addrs,ptr)-1
    if i<0: return ("?",0)
    a,nm=tsyms[i]; return (nm, ptr-a)
def demangle1(s):
    f=subprocess.Popen(["c++filt"],stdin=subprocess.PIPE,stdout=subprocess.PIPE)
    return f.communicate(s)[0].strip()
def fileoff(vmaddr):
    best=None
    for sg in segs:
        if sg.get("addr",0)<=vmaddr and vmaddr<sg["addr"]+0x400000 and (best is None or sg["addr"]>best["addr"]): best=sg
    return best["off"]+(vmaddr-best["addr"])
if sys.argv[1:2]==["--find"]:
    import re as _re
    pat=_re.compile(sys.argv[2])
    base=vt+0x10
    for i in range(0,0x800):
        slot=base+i*8
        ptr=struct.unpack("<Q",data[fileoff(slot):fileoff(slot)+8])[0]
        if ptr==0: continue
        nm,delta=name_at(ptr)
        if delta==0:
            d=demangle1(nm)
            if pat.search(d): print "0x%-6x ->  %s" % (i*8, d)
else:
    for off in sys.argv[1:]:
        slot=vt+0x10+int(off,16); ptr=struct.unpack("<Q",data[fileoff(slot):fileoff(slot)+8])[0]
        nm,delta=name_at(ptr)
        print "%-8s ->  %s%s" % (off, demangle1(nm), ("  (+0x%x)"%delta) if delta else "")
PY
}

sub_strings() {  # <target> ["filter regex"]
  bin=$(re_resolve "$1"); pat=${2:-.}; minlen=${RE_MINLEN:-4}
  [ -n "$1" ] || { echo "usage: $me strings <target> [\"filter regex\"]" >&2; return 2; }
  echo "# strings in $bin matching: $pat"
  echo "# columns: offset  string"
  re_strings_src "$bin" "$minlen" | awk -v q="$pat" '
    { off=$1; sub(/^[0-9a-f]+[ \t]+/,""); if ($0 ~ q) printf "0x%s\t%s\n", off, $0 }'
}

sub_consts() {  # <target> [seg] [sec]
  bin=$(re_resolve "$1"); seg=${2:-__TEXT}; sec=${3:-__const}
  [ -n "$1" ] || { echo "usage: $me consts <target> [seg] [sec]" >&2; return 2; }
  echo "# section $seg,$sec of $bin ($arch)"
  if re_cache_only "$bin"; then
    dyld_info "$bin" -arch "$arch" -section "$seg" "$sec" 2>/dev/null
  else
    otool -v -arch "$arch" -s "$seg" "$sec" "$bin" 2>/dev/null
  fi
}

sub_hex() {  # <file-or-alias> [offset] [length]  (offset is a FILE offset; for these Mach-O plugins vaddr==fileoff in __TEXT)
  f=$(re_resolve "$1")
  [ -n "$f" ] || { echo "usage: $me hex <file> [offset] [length]" >&2; return 2; }
  [ -f "$f" ] || { echo "# hex: $f (NOT FOUND)" >&2; return 1; }
  off=$(re_hexnum "${2:-0}"); len=$(re_hexnum "${3:-256}")
  echo "# hex: $f"
  if [ "$len" -eq 0 ]; then
    echo "# window: offset $off .. EOF"
    if command -v xxd >/dev/null 2>&1; then xxd -s "$off" "$f"; else od -A x -t x1z -v -j "$off" "$f"; fi
  else
    echo "# window: offset $off length $len"
    if command -v xxd >/dev/null 2>&1; then xxd -s "$off" -l "$len" "$f"; else od -A x -t x1z -v -j "$off" -N "$len" "$f"; fi
  fi
}

sub_bcmp() {  # <fileA> <fileB> [offset] [length]
  a=$1; b=$2
  [ -f "$a" ] && [ -f "$b" ] || { echo "usage: $me bcmp <fileA> <fileB> [offset] [length]" >&2; return 2; }
  off=$(re_hexnum "${3:-0}"); lenarg=$4
  echo "# bcmp: A=$a"; echo "#       B=$b"
  if [ -n "$lenarg" ]; then
    len=$(re_hexnum "$lenarg"); echo "# window: offset $off length $len"
    da=$(dd if="$a" bs=1 skip="$off" count="$len" 2>/dev/null | od -An -tx1)
    db=$(dd if="$b" bs=1 skip="$off" count="$len" 2>/dev/null | od -An -tx1)
  else
    echo "# window: offset $off .. EOF"
    da=$(dd if="$a" bs=1 skip="$off" 2>/dev/null | od -An -tx1)
    db=$(dd if="$b" bs=1 skip="$off" 2>/dev/null | od -An -tx1)
  fi
  if [ "$da" = "$db" ]; then echo "IDENTICAL"; else
    i=0; set -- $db; bb="$*"; set -- $da
    for byte in "$@"; do
      j=$(echo "$bb" | cut -d' ' -f$((i+1))); [ "$byte" != "$j" ] && break; i=$((i+1))
    done
    printf 'DIFFER at +0x%x (file offset 0x%x)\n' "$i" $((off+i))
  fi
}

sub_plist() {  # <target> [keypath] [filter]
  target=$1; key=$2; filter=$3
  [ -n "$target" ] || { echo "usage: $me plist <target> [keypath] [filter]" >&2; return 2; }
  f=$(re_resolve_plist "$target")
  [ -f "$f" ] || { echo "# plist: $f (NOT FOUND)" >&2; return 1; }
  if [ -n "$key" ]; then
    echo "# plist: $f"; echo "# key:   $key"; /usr/libexec/PlistBuddy -c "Print :$key" "$f"
  else
    echo "# plist: $f"; plutil -p "$f"
  fi | { [ -n "$filter" ] && grep -iE "^#|$filter" || cat; }
}

sub_amd_actuation() {  # [ioreg-dump-file]
  src=${1:-}
  if [ -n "$src" ]; then dump=$(cat "$src"); else dump=$(ioreg -l -w0 2>/dev/null); fi
  amd=$(printf '%s\n' "$dump" | grep -cE 'class AppleMultitouchDevice,')
  hidev=$(printf '%s\n' "$dump" | grep -cE 'class AppleMultitouchHIDEventDriver,')
  pointing=$(printf '%s\n' "$dump" | grep -cE 'class IOHIDPointing,')
  echo "  AppleMultitouchDevice=$amd AppleMultitouchHIDEventDriver=$hidev IOHIDPointing=$pointing"
  if [ "$amd" -ge 1 ] && [ "$hidev" -ge 1 ] && [ "$pointing" -ge 1 ]; then
    echo "VERDICT: STEADY amd-actuation wired"
  else
    echo "VERDICT: BROKEN amd-actuation missing (need AppleMultitouchHIDEventDriver + IOHIDPointing)"
  fi
}

sub_conn_trace() {  # [logfile]   (no arg = stdin)
  src=${1:-/dev/stdin}
  grep 'CONNTRACE ' "$src" | awk '
    {
      for (i = 1; i <= NF; i++) {
        n = index($i, "="); if (!n) continue
        k = substr($i, 1, n-1); v = substr($i, n+1)
        if (k == "conn")  conn = v; if (k == "state") state = v
        if (k == "event") event = v; if (k == "ts")    ts = v
      }
      print "  conn=" conn " ts=" ts " " state " <- " event
      if (event == "DISCONNECT") next
      last[conn] = state; seen[conn] = 1
      if (state == "STEADY") steady[conn] = 1
    }
    END {
      for (c in seen) {
        if (steady[c]) print "VERDICT: STEADY conn=" c
        else print "VERDICT: FAIL conn=" c " stalled at " last[c]
      }
    }'
}

sub_bt_timeline() {  # [tail-N]  — MT2 BT connect activity across ALL layers, newest N (default 60)
  # Unlike conn-trace (which parses only OUR kext's CONNTRACE, so it's empty when the connection
  # never reaches us), this extracts the whole ladder from the syslog so a login-screen "click did
  # nothing" is diagnosable: did the device PAGE the host at all, or did it stall further up?
  # Tags:  [PAGE] baseband/HCI connection to the device   [HCI ] controller/transport
  #        [blud] blued userland (link key / connect)      [HID ] Apple BT HID (BNB/AppleBluetoothMultitouch)
  #        [OURS] our reader / CONNTRACE.   Lines touching the MT2's address are flagged *MT2*.
  n=${1:-60}
  mt2=04-4b-ed-ec-02-07
  grep -iE "bluetooth|HCI|BNB|baseband| ACL |link key|incoming connection|connection request|paging|page scan|AppleBluetoothMultitouch|IOBluetoothHIDDriver|CONNTRACE|MT2BTReader|MavericksVoodooInputHost|$mt2" /var/log/system.log 2>/dev/null \
    | grep -ivE "SuspendDevice|iCloudHelper|com.apple.audio|DriverHelper|cs_invalid_page|GPU Hardware|vm_page_bootstrap|Got boot device|sudo\[|COMMAND=|kextd|MT2PaneRefresh" \
    | tail -"$n" \
    | awk -v mt2="$mt2" '
        {
          tag="[bt  ]"
          if      ($0 ~ /CONNTRACE|MT2BTReader|MavericksVoodooInputHost/)                          tag="[OURS]"
          else if ($0 ~ /IOBluetoothHIDDriver|AppleBluetoothMultitouch|BNBTrackpad/) tag="[HID ]"
          else if ($0 ~ /[Bb]lued/)                                                  tag="[blud]"
          else if ($0 ~ /[Cc]onnection [Rr]equest|[Ii]ncoming [Cc]onnection|[Pp]aging|page scan|[Aa][Cc][Ll]/) tag="[PAGE]"
          else if ($0 ~ /HCIController|HostController|baseband/)                      tag="[HCI ]"
          flag = ($0 ~ mt2) ? " *MT2*" : ""
          print tag flag "  " $0
        }'
}

sub_ioreg_class() {  # <IOClassName> [more...]
  [ -n "$1" ] || { echo "usage: $me ioreg-class <IOClassName> [more...]" >&2; return 2; }
  dump=$(ioreg -l -w0 2>/dev/null)
  for cls in "$@"; do
    echo "# $cls"
    printf '%s\n' "$dump" | grep -E "\+-o $cls " | sed -E 's/ <class.*//; s/^ *//'
    printf '  count: %s\n' "$(printf '%s\n' "$dump" | grep -cE "class $cls,")"
  done
}

sub_ioreg_props() {  # <IOClassName> [filter]
  cls=$1; filter=$2
  [ -n "$cls" ] || { echo "usage: $me ioreg-props <IOClassName> [filter]" >&2; return 2; }
  sudo ioreg -r -c "$cls" -l -w0 | { [ -n "$filter" ] && grep -iE "\+-o |$filter" || cat; }
}

sub_klog() {  # "<regex>" [tail-N]
  pat=${1:-.}; n=${2:-25}
  grep -E "kernel\[[0-9]*\]" /var/log/system.log 2>/dev/null | grep -iE "$pat" | tail -"$n"
}

sub_kexts() {  # ["name regex"]
  pat=${1:-.}
  kextstat 2>/dev/null | grep -iE "$pat|^Index" | grep -ivE "grep"
}

