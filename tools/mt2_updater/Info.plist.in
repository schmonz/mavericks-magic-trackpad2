<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleIdentifier</key>
	<string>com.schmonz.MavericksTrackpad2Updater</string>
	<!-- CFBundleName is the host name Sparkle shows in its dialogs ("A new version of X is
	     available", "You're up to date"), so it's the PRODUCT name, not the helper's internal name.
	     CFBundleExecutable/Identifier/IconFile keep the internal MavericksTrackpad2Updater name. -->
	<key>CFBundleName</key>
	<string>Mavericks Trackpad 2</string>
	<key>CFBundleExecutable</key>
	<string>MavericksTrackpad2Updater</string>
	<!-- Product icon for Sparkle's update dialog (else it shows a generic app icon).
	     Art = Apple's TrackpadPicture.png, the same trackpad image the pane reuses. -->
	<key>CFBundleIconFile</key>
	<string>MavericksTrackpad2Updater</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleShortVersionString</key>
	<string>@MT2_VERSION@</string>
	<key>CFBundleVersion</key>
	<string>@MT2_VERSION@</string>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>
	<!-- A NORMAL foreground app (not LSUIElement). Sparkle's update flow assumes a standard
	     LaunchServices-launched app: an LSUIElement accessory helper fought window foregrounding, and
	     (with a fork+exec launch) its non-LaunchServices host made Sparkle's Autoupdate unable to detect
	     the host quit -> the install hung. Being a normal app launched via `open` restores the standard,
	     working flow. Cost: a brief Dock icon while checking/installing, which is the normal Sparkle UX. -->
	<key>LSMinimumSystemVersion</key>
	<string>10.9</string>
	<key>SUFeedURL</key>
	<string>https://github.com/schmonz/mavericks-magic-trackpad2/releases/latest/download/appcast.xml</string>
	<!-- EdDSA public key (from generate_keys; matching private key is CI secret SPARKLE_PRIVATE_KEY).
	     Sparkle verifies every update against this. -->
	<key>SUPublicEDKey</key>
	<string>E8ZTStxLUfSWtTDg24bwnanLII20R27NVm+RxZtElGs=</string>
	<key>SUEnableAutomaticChecks</key>
	<false/>
</dict>
</plist>
