<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleIdentifier</key>
	<string>com.schmonz.MavericksTrackpad2Updater</string>
	<key>CFBundleName</key>
	<string>MavericksTrackpad2Updater</string>
	<key>CFBundleExecutable</key>
	<string>MavericksTrackpad2Updater</string>
	<!-- Product icon for Sparkle's update dialog (else it shows a generic app icon).
	     Art = Apple's TrackpadPicture.png, the same trackpad image the pane reuses. -->
	<key>CFBundleIconFile</key>
	<string>MavericksTrackpad2Updater</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleShortVersionString</key>
	<string>@MT2_VERSION@</string>
	<key>CFBundleVersion</key>
	<string>@MT2_VERSION@</string>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>
	<key>LSUIElement</key>
	<true/>
	<key>LSMinimumSystemVersion</key>
	<string>10.9</string>
	<key>SUFeedURL</key>
	<string>https://github.com/schmonz/mavericks-magic-trackpad2/releases/latest/download/appcast.xml</string>
	<!-- EdDSA public key (from generate_keys; matching private key is CI secret SPARKLE_PRIVATE_KEY).
	     Sparkle verifies every update against this. -->
	<key>SUPublicEDKey</key>
	<string>E8ZTStxLUfSWtTDg24bwnanLII20R27NVm+RxZtElGs=</string>
	<key>SUEnableAutomaticChecks</key>
	<false/>
</dict>
</plist>
