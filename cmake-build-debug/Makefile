	$(MAKE) $(MAKESILENT) -f CMakeFiles/Makefile2 test_single_load
.PHONY : test_single_load

# fast build rule for target.
test_single_load/fast:
	$(MAKE) $(MAKESILENT) -f tests/CMakeFiles/test_single_load.dir/build.make tests/CMakeFiles/test_single_load.dir/build
.PHONY : test_single_load/fast

