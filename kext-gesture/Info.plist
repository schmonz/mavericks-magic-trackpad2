<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>English</string>
    <key>CFBundleExecutable</key>
    <string>MT2Gesture</string>
    <key>CFBundleIdentifier</key>
    <string>com.schmonz.MT2Gesture</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>MT2Gesture</string>
    <key>CFBundlePackageType</key>
    <string>KEXT</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    <key>CFBundleSignature</key>
    <string>????</string>
    <key>CFBundleVersion</key>
    <string>1.0.0</string>
    <key>OSBundleRequired</key>
    <string>Root</string>
    <key>IOKitPersonalities</key>
    <dict>
        <key>MT2Gesture</key>
        <dict>
            <key>CFBundleIdentifier</key>
            <string>com.schmonz.MT2Gesture</string>
            <key>IOClass</key>
            <string>com_schmonz_MT2Gesture</string>
            <key>IOProviderClass</key>
            <string>IOResources</string>
            <key>IOMatchCategory</key>
            <string>com_schmonz_MT2Gesture</string>
            <key>IOResourceMatch</key>
            <string>IOKit</string>
            <key>IOUserClientClass</key>
            <string>com_schmonz_MT2GestureUserClient</string>
        </dict>
        <key>MT2HIDEventDriver</key>
        <dict>
            <!-- Drive Apple's AppleMultitouchHIDEventDriver (the AppleMultitouch
                 event service the gesture wrapper wires to) onto our in-kernel MT1
                 HID interface. Mirrors AppleBluetoothMultitouch's BNBTrackpadEvent
                 Driver personality, which is NOT in the live catalogue, so the
                 generic IOHIDEventDriver wins by default. High IOProbeScore +
                 specific VendorID/ProductID/VendorIDSource match beats it. The
                 IOClass lives in com.apple.driver.AppleMultitouchDriver (our
                 OSBundleLibrary), so CFBundleIdentifier points there. -->
            <key>CFBundleIdentifier</key>
            <string>com.apple.driver.AppleMultitouchDriver</string>
            <key>IOClass</key>
            <string>AppleMultitouchHIDEventDriver</string>
            <key>IOProviderClass</key>
            <string>IOHIDInterface</string>
            <key>VendorID</key>
            <integer>1452</integer>
            <key>ProductID</key>
            <integer>782</integer>
            <key>VendorIDSource</key>
            <integer>2</integer>
            <key>IOProbeScore</key>
            <integer>100000</integer>
        </dict>
    </dict>
    <key>OSBundleLibraries</key>
    <dict>
        <key>com.apple.kpi.iokit</key>
        <string>13.4</string>
        <key>com.apple.kpi.libkern</key>
        <string>13.4</string>
        <key>com.apple.driver.AppleMultitouchDriver</key>
        <string>193.8</string>
        <key>com.apple.iokit.IOHIDFamily</key>
        <string>1.5</string>
    </dict>
</dict>
</plist>
