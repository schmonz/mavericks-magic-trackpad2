<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>English</string>
    <key>CFBundleExecutable</key>
    <string>MT2Gesture</string>
    <key>CFBundleIdentifier</key>
    <string>com.schmonz.MT2Gesture</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>MT2Gesture</string>
    <key>CFBundlePackageType</key>
    <string>KEXT</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    <key>CFBundleSignature</key>
    <string>????</string>
    <key>CFBundleVersion</key>
    <string>1.0.0</string>
    <key>OSBundleRequired</key>
    <string>Root</string>
    <key>IOKitPersonalities</key>
    <dict>
        <key>MT2Gesture</key>
        <dict>
            <key>CFBundleIdentifier</key>
            <string>com.schmonz.MT2Gesture</string>
            <key>IOClass</key>
            <string>com_schmonz_MT2Gesture</string>
            <key>IOProviderClass</key>
            <string>IOResources</string>
            <key>IOMatchCategory</key>
            <string>com_schmonz_MT2Gesture</string>
            <key>IOResourceMatch</key>
            <string>IOKit</string>
        </dict>
        <key>MT2HIDEventDriver</key>
        <dict>
            <!-- Drive Apple's AppleMultitouchHIDEventDriver (the AppleMultitouch
                 event service the gesture wrapper wires to) onto our in-kernel MT1
                 HID interface. Mirrors AppleBluetoothMultitouch's BNBTrackpadEvent
                 Driver personality, which is NOT in the live catalogue, so the
                 generic IOHIDEventDriver wins by default. High IOProbeScore +
                 specific VendorID/ProductID/VendorIDSource match beats it. The
                 IOClass lives in com.apple.driver.AppleMultitouchDriver (our
                 OSBundleLibrary), so CFBundleIdentifier points there. -->
            <key>CFBundleIdentifier</key>
            <string>com.apple.driver.AppleMultitouchDriver</string>
            <key>IOClass</key>
            <string>AppleMultitouchHIDEventDriver</string>
            <key>IOProviderClass</key>
            <string>IOHIDInterface</string>
            <key>VendorID</key>
            <integer>1452</integer>
            <key>ProductID</key>
            <integer>782</integer>
            <key>VendorIDSource</key>
            <integer>2</integer>
            <key>IOProbeScore</key>
            <integer>100000</integer>
        </dict>
        <!-- Cursor actuation for FULL-BNB: genuine BNBTrackpadDevice publishes its
             IOHIDInterface with the MT2's real BT identity (VID 76 / PID 613 / source 1),
             which Apple's BNBTrackpadEventDriver (VID 1452 / source 2) does NOT match, so
             the AMD gets no AppleMultitouchHIDEventDriver -> no IOHIDPointing -> no cursor.
             This personality is the VID-76 twin of MT2HIDEventDriver above: same IOClass /
             CFBundleIdentifier / probe score, keyed to BNB's actual identity, so Apple's
             event driver binds BNB's interface and drives the cursor. Inert when no such
             interface is present (fDevice mode), so it needs no flag gating. -->
        <key>MT2HIDEventDriverBNB</key>
        <dict>
            <key>CFBundleIdentifier</key>
            <string>com.apple.driver.AppleMultitouchDriver</string>
            <key>IOClass</key>
            <string>AppleMultitouchHIDEventDriver</string>
            <key>IOProviderClass</key>
            <string>IOHIDInterface</string>
            <key>VendorID</key>
            <integer>76</integer>
            <key>ProductID</key>
            <integer>613</integer>
            <key>VendorIDSource</key>
            <integer>1</integer>
            <key>IOProbeScore</key>
            <integer>100000</integer>
        </dict>
        <!-- USB cursor actuation (genuine-USB path). Apple drives the pointer only when a matched
             AppleUSBMultitouchHIDEventDriver lives in the genuine driver's subtree (its
             hidEventDriverPublished -> AppleMultitouchEventDriverWrapper -> IOHIDPointing, fed by
             the multitouch frames our reframe delivers). Apple's own AppleUSBMultitouchHIDEventDriver
             personality requires DeviceUsage {0xFF00,1} + MTEventSource, but the genuine driver
             publishes our MT2's interface as DeviceUsage {0xFF00,12} with no MTEventSource, so it
             never binds -> no cursor. This is the USB twin of MT2HIDEventDriverBNB: same IOClass /
             CFBundleIdentifier, keyed to the MT2's real USB identity (VID 1452 / PID 613), high
             probe score, so Apple's event driver binds our interface and actuates the cursor.
             Inert unless the genuine USB driver published such an interface (kGenuineUsb path). -->
        <key>MT2USBHIDEventDriver</key>
        <dict>
            <key>CFBundleIdentifier</key>
            <string>com.apple.driver.AppleUSBMultitouch</string>
            <key>IOClass</key>
            <string>AppleUSBMultitouchHIDEventDriver</string>
            <key>IOProviderClass</key>
            <string>IOHIDInterface</string>
            <key>VendorID</key>
            <integer>1452</integer>
            <key>ProductID</key>
            <integer>613</integer>
            <key>IOProbeScore</key>
            <integer>100000</integer>
        </dict>
        <!-- Bind the Magic Trackpad 2's Bluetooth L2CAP channels by its BT-SIG identity
             (VendorID 76 / ProductID 613 / VendorIDSource 1). NO IOMatchCategory: we
             compete in the DEFAULT category against the generic IOBluetoothHIDDriver
             (which matches PSM 17, default category, probe score 0) and win on our high
             IOProbeScore + specific VID/PID, EXCLUDING it. That hands us the device so
             our interrupt listener is the sole reader. Two personalities (control PSM 17,
             interrupt PSM 19); both resolve to com_schmonz_MT2BTReader, which branches on
             getPSM(): send the 0xF1 enable on control, listenAt on both. -->
        <key>MT2BTControl</key>
        <dict>
            <key>CFBundleIdentifier</key>
            <string>com.schmonz.MT2Gesture</string>
            <key>IOClass</key>
            <string>com_schmonz_MT2BTReader</string>
            <key>IOProviderClass</key>
            <string>IOBluetoothL2CAPChannel</string>
            <key>PSM</key>
            <integer>17</integer>
            <key>VendorID</key>
            <integer>76</integer>
            <key>ProductID</key>
            <integer>613</integer>
            <key>VendorIDSource</key>
            <integer>1</integer>
            <key>IOProbeScore</key>
            <integer>100000</integer>
        </dict>
        <key>MT2BTInterrupt</key>
        <dict>
            <key>CFBundleIdentifier</key>
            <string>com.schmonz.MT2Gesture</string>
            <key>IOClass</key>
            <string>com_schmonz_MT2BTReader</string>
            <key>IOProviderClass</key>
            <string>IOBluetoothL2CAPChannel</string>
            <key>PSM</key>
            <integer>19</integer>
            <key>VendorID</key>
            <integer>76</integer>
            <key>ProductID</key>
            <integer>613</integer>
            <key>VendorIDSource</key>
            <integer>1</integer>
            <key>IOProbeScore</key>
            <integer>100000</integer>
        </dict>
        <!-- Bind interface 1 of the cabled Magic Trackpad 2 (idVendor 1452 /
             idProduct 613). High IOProbeScore beats IOUSBHIDDriver so our active
             reader owns the interrupt-IN pipe. Resolves to com_schmonz_MT2USBReader
             (in this kext), which feeds the nub as MT2_STREAMING. Replaces the
             inert MT2USBClaim kext + the userspace feeder. -->
        <key>MT2USB</key>
        <dict>
            <key>CFBundleIdentifier</key>
            <string>com.schmonz.MT2Gesture</string>
            <key>IOClass</key>
            <string>com_schmonz_MT2USBReader</string>
            <key>IOProviderClass</key>
            <string>IOUSBInterface</string>
            <key>idVendor</key>
            <integer>1452</integer>
            <key>idProduct</key>
            <integer>613</integer>
            <key>bConfigurationValue</key>
            <integer>1</integer>
            <key>bInterfaceNumber</key>
            <integer>1</integer>
            <key>IOProbeScore</key>
            <integer>500000</integer>
        </dict>
    </dict>
    <key>OSBundleLibraries</key>
    <dict>
        <key>com.apple.kpi.iokit</key>
        <string>13.4</string>
