#!/bin/sh
# ioreg-props - dump a live IORegistry class's node(s) + properties (read-only).
# Unix filter: writes the ioreg subtree to stdout. Optional [filter] regex keeps only matching
# property lines (plus the '+-o' node header lines) so one property check stays a single command
# instead of `ioreg ... | grep`.
# Usage: ioreg-props <IOClassName> [filter]
#   ioreg-props AppleMultitouchDevice
#   ioreg-props AppleUSBMultitouchDriver "IOUserClientClass|Multitouch ID"
cls=$1; filter=$2
[ -n "$cls" ] || { echo "usage: $(basename "$0") <IOClassName> [filter]" >&2; exit 2; }
sudo ioreg -r -c "$cls" -l -w0 | { [ -n "$filter" ] && grep -iE "\+-o |$filter" || cat; }
