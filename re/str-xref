#!/bin/sh
# str-xref - find where a C string is USED in code, via the disassembler's resolved
# "## literal pool for: \"...\"" annotations. Answers "which code path keys on this
# class-name / property string?" without hand-computing VM addresses.
#
# Reports the ENCLOSING FUNCTION for each reference (so string -> function is ONE step;
# follow up with `re/disasm <target> "<that function>"`), plus a disassembly window so you
# can see what the string is passed to (IOServiceMatching, a compare, a log call, ...).
#
# Usage: str-xref <target> "<substring of the string>" [context-lines]   # default 8 before, 3 after
#   target: a path (e.g. captures/kc/Foo.rebased) OR an alias (Trackpad/Mouse/MultitouchHID/
#   MultitouchSupport/AppleBluetoothMultitouch/AppleMultitouchDriver/AppleUSBMultitouch).
#   Substring match (NOT whole-cstring) — unlike the old version, partial strings work.
#   Arch defaults to x86_64; override with RE_ARCH=i386.
#
# Output per hit:
#   === <enclosing function> ===
#   <ctx lines> ... <the leaq ... ## "string"> ... <3 lines>
#
# Example:
#   str-xref MultitouchHID mech_click_ctr     # which function logs the physical-click counter
arch=${RE_ARCH:-x86_64}
resolve() {
  case "$1" in
    Trackpad)                 echo "/System/Library/PreferencePanes/Trackpad.prefPane/Contents/MacOS/Trackpad" ;;
    Mouse)                    echo "/System/Library/PreferencePanes/Mouse.prefPane/Contents/MacOS/Mouse" ;;
    MultitouchHID)            echo "/System/Library/Extensions/AppleMultitouchDriver.kext/Contents/PlugIns/MultitouchHID.plugin/Contents/MacOS/MultitouchHID" ;;
    MultitouchSupport)        echo "/System/Library/PrivateFrameworks/MultitouchSupport.framework/Versions/A/MultitouchSupport" ;;
    AppleBluetoothMultitouch) echo "/System/Library/Extensions/AppleBluetoothMultitouch.kext/Contents/MacOS/AppleBluetoothMultitouch" ;;
    AppleMultitouchDriver)    echo "/System/Library/Extensions/AppleMultitouchDriver.kext/Contents/MacOS/AppleMultitouchDriver" ;;
    AppleUSBMultitouch)       echo "/System/Library/Extensions/AppleUSBMultitouch.kext/Contents/MacOS/AppleUSBMultitouch" ;;
    *)                        echo "$1" ;;
  esac
}
bin=$(resolve "$1"); q=$2; ctx=${3:-8}
[ -n "$2" ] || { echo "usage: $(basename "$0") <target> \"<substring of the string>\" [context-lines]" >&2; exit 2; }

echo "# code referencing \"$q\" in $bin ($arch)  — enclosing function + window (ctx ${ctx}/3)"
otool -tV -arch "$arch" "$bin" 2>/dev/null | c++filt | awk -v q="$q" -v ctx="$ctx" '
  # function label lines: end in ":" and are not address-prefixed instructions
  /:$/ && $1 !~ /^[0-9a-f]{5,16}/ { fn=$0; sub(/:$/,"",fn) }
  { L[NR]=$0; F[NR]=fn }
  index($0,q)>0 { hit[++h]=NR }
  END {
    if (h==0) { print "# (no references found)"; exit 1 }
    for (j=1;j<=h;j++) {
      m=hit[j]; printf "=== %s ===\n", (F[m]==""?"?":F[m])
      lo=m-ctx; if (lo<1) lo=1
      for (i=lo;i<=m+3;i++) if (i in L) print L[i]
      print ""
    }
  }'
