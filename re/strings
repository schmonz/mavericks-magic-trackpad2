#!/bin/sh
# strings - list a binary's printable C strings by readable filter, with file offsets.
#
# For finding the constants a binary keys on: matched class names (IOServiceMatching),
# property keys (IORegistryEntryCreateCFProperty), and user-facing messages that mark a
# code path ("No trackpad found"). Output:
#
#   # strings in <path> matching: <filter>
#   # columns: offset  string
#   0x1a2b0  AppleMultitouchDevice
#
# '#' lines are comments; body splits on first whitespace (offset=$1, string=rest).
#
# Usage: strings <target> ["filter regex"]    # target: path or an alias below
#   min length defaults to 4; override with RE_MINLEN=N.
#
# Examples:
#   strings Trackpad "Trackpad|Bluetooth|found"
#   strings Trackpad "Device$"          # candidate IOService class names
minlen=${RE_MINLEN:-4}
resolve() {
  case "$1" in
    Trackpad)                 echo "/System/Library/PreferencePanes/Trackpad.prefPane/Contents/MacOS/Trackpad" ;;
    Mouse)                    echo "/System/Library/PreferencePanes/Mouse.prefPane/Contents/MacOS/Mouse" ;;
    MultitouchHID)            echo "/System/Library/Extensions/AppleMultitouchDriver.kext/Contents/PlugIns/MultitouchHID.plugin/Contents/MacOS/MultitouchHID" ;;
    MultitouchSupport)        echo "/System/Library/PrivateFrameworks/MultitouchSupport.framework/Versions/A/MultitouchSupport" ;;
    AppleBluetoothMultitouch) echo "/System/Library/Extensions/AppleBluetoothMultitouch.kext/Contents/MacOS/AppleBluetoothMultitouch" ;;
    *)                        echo "$1" ;;
  esac
}
bin=$(resolve "$1"); pat=${2:-.}
[ -n "$1" ] || { echo "usage: $(basename "$0") <target> [\"filter regex\"]   (target: path or alias Trackpad/Mouse/MultitouchHID/MultitouchSupport/AppleBluetoothMultitouch)" >&2; exit 2; }

echo "# strings in $bin matching: $pat"
echo "# columns: offset  string"
strings -a -t x -n "$minlen" "$bin" 2>/dev/null | awk -v q="$pat" '
  { off=$1; sub(/^[0-9a-f]+[ \t]+/,""); if ($0 ~ q) printf "0x%s\t%s\n", off, $0 }'
