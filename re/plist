#!/bin/sh
# plist - read a plist (kext/bundle Info.plist, or any .plist) BY NAME, readably (read-only).
#
# Unix filter: resolves a short alias (or path) to a plist and dumps it to stdout, so RE that
# needs Info.plist values (DefaultMultitouchProperties, ExtendedFeatures, IOKitPersonalities,
# geometry, parser-type, ...) stays allowlist-friendly instead of hand-running PlistBuddy/defaults.
#
# Output (humans AND pipes): a '#'-prefixed header naming the file (+ key), then the value.
#   - whole plist  -> `plutil -p` (readable "key" => value tree)
#   - a key path   -> `PlistBuddy -c "Print :<keypath>"` (xml-ish subtree)
# Skip the header with `grep -v '^#'`; narrow with the optional filter (a regex kept from the body).
#
# Usage: plist <target> [keypath] [filter]
#   plist AppleBluetoothMultitouch                                  # whole Info.plist
#   plist AppleBluetoothMultitouch IOKitPersonalities               # one key path (':' nested ok)
#   plist AppleBluetoothMultitouch "" "parser-type|ExtendedFeatures"  # whole plist, grep filter
#   <target> = a kext/plugin/framework alias, a .kext/.plugin/.framework bundle path, or a .plist path.

resolve() {
  case "$1" in
    MultitouchHID)            echo "/System/Library/Extensions/AppleMultitouchDriver.kext/Contents/PlugIns/MultitouchHID.plugin/Contents/Info.plist" ;;
    MultitouchSupport)        echo "/System/Library/PrivateFrameworks/MultitouchSupport.framework/Resources/Info.plist" ;;
    AppleBluetoothMultitouch) echo "/System/Library/Extensions/AppleBluetoothMultitouch.kext/Contents/Info.plist" ;;
    AppleUSBMultitouch)       echo "/System/Library/Extensions/AppleUSBMultitouch.kext/Contents/Info.plist" ;;
    AppleMultitouchDriver)    echo "/System/Library/Extensions/AppleMultitouchDriver.kext/Contents/Info.plist" ;;
    IOBluetoothHIDDriver)     echo "/System/Library/Extensions/IOBluetoothHIDDriver.kext/Contents/Info.plist" ;;
    IOBluetoothFamily)        echo "/System/Library/Extensions/IOBluetoothFamily.kext/Contents/Info.plist" ;;
    IOHIDFamily)              echo "/System/Library/Extensions/IOHIDFamily.kext/Contents/Info.plist" ;;
    *.plist)                  echo "$1" ;;
    *.kext|*.plugin|*.framework|*.app)  echo "$1/Contents/Info.plist" ;;
    *)                        [ -d "$1" ] && echo "$1/Contents/Info.plist" || echo "$1" ;;
  esac
}

target=$1; key=$2; filter=$3
[ -n "$target" ] || { echo "usage: $(basename "$0") <target> [keypath] [filter]" >&2; exit 2; }

f=$(resolve "$target")
[ -f "$f" ] || { echo "# plist: $f (NOT FOUND)" >&2; exit 1; }

if [ -n "$key" ]; then
  echo "# plist: $f"
  echo "# key:   $key"
  /usr/libexec/PlistBuddy -c "Print :$key" "$f"
else
  echo "# plist: $f"
  plutil -p "$f"
fi | { [ -n "$filter" ] && grep -iE "^#|$filter" || cat; }
