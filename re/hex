#!/bin/sh
# hex - readable hex+ASCII dump of a file (or a byte window of it), BY NAME.
#
# A thin, allowlist-friendly wrapper over xxd/od so RE that needs to eyeball raw bytes
# (magic numbers, struct layouts, packet captures, a slice of a kext/kernelcache) stays
# ONE literal command -- no hand-built `dd | xxd` pipe, no $VAR-passed offsets.
#
# Output: a '#'-prefixed header (file + window), then `xxd`-style rows:
#   00000000: cafe babe 0000 0001  ........
# '#' lines are comments; skip with `grep -v '^#'`.
#
# Usage: hex <file> [offset] [length]
#   offset, length accept decimal or 0x-hex. Default offset 0, default length 256.
#   hex /path/to/bin                 # first 256 bytes
#   hex /path/to/bin 0x9376 64       # 64 bytes at file offset 0x9376
#   hex /path/to/bin 0 0            # length 0 => whole file
n() { case "$1" in 0x*|0X*) printf '%d' "$1" ;; *) printf '%d' "${1:-0}" ;; esac; }

f=$1
[ -n "$f" ] || { echo "usage: $(basename "$0") <file> [offset] [length]" >&2; exit 2; }
[ -f "$f" ] || { echo "# hex: $f (NOT FOUND)" >&2; exit 1; }

off=$(n "${2:-0}")
len=$(n "${3:-256}")

echo "# hex: $f"
if [ "$len" -eq 0 ]; then
  echo "# window: offset $off .. EOF"
  if command -v xxd >/dev/null 2>&1; then xxd -s "$off" "$f"
  else od -A x -t x1z -v -j "$off" "$f"; fi
else
  echo "# window: offset $off length $len"
  if command -v xxd >/dev/null 2>&1; then xxd -s "$off" -l "$len" "$f"
  else od -A x -t x1z -v -j "$off" -N "$len" "$f"; fi
fi
