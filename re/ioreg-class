#!/bin/sh
# ioreg-class - presence/count + one-line node summary for live IORegistry classes.
# Read-only. Answers "is <class> in the registry right now, how many, and where".
# Unix filter: per class, the matching `+-o` node lines then a count.
# Usage: ioreg-class <IOClassName> [more classes...]
#   ioreg-class BNBTrackpadDevice com_schmonz_MT2BTReader IOBluetoothL2CAPChannel
[ -n "$1" ] || { echo "usage: $(basename "$0") <IOClassName> [more...]" >&2; exit 2; }
dump=$(ioreg -l -w0 2>/dev/null)
for cls in "$@"; do
  echo "# $cls"
  printf '%s\n' "$dump" | grep -E "\+-o $cls " | sed -E 's/ <class.*//; s/^ *//'
  printf '  count: %s\n' "$(printf '%s\n' "$dump" | grep -cE "class $cls,")"
done
