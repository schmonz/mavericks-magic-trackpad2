#!/bin/sh
# consts - dump a Mach-O section (for resolving constants / float thresholds).
# Usage: consts <target> [segment] [section]
#   defaults: segment __TEXT, section __const. Arch defaults x86_64 (RE_ARCH overrides).
#   <target> is a path OR an alias (MultitouchHID/MultitouchSupport/AppleBluetoothMultitouch/AppleMultitouchDriver).
#   consts MultitouchHID __TEXT __const
#   consts MultitouchHID __DATA  __data
arch=${RE_ARCH:-x86_64}
resolve() {
  case "$1" in
    MultitouchHID)            echo "/System/Library/Extensions/AppleMultitouchDriver.kext/Contents/PlugIns/MultitouchHID.plugin/Contents/MacOS/MultitouchHID" ;;
    MultitouchSupport)        echo "/System/Library/PrivateFrameworks/MultitouchSupport.framework/Versions/A/MultitouchSupport" ;;
    AppleBluetoothMultitouch) echo "/System/Library/Extensions/AppleBluetoothMultitouch.kext/Contents/MacOS/AppleBluetoothMultitouch" ;;
    AppleMultitouchDriver)    echo "/System/Library/Extensions/AppleMultitouchDriver.kext/Contents/MacOS/AppleMultitouchDriver" ;;
    *)                        echo "$1" ;;
  esac
}
bin=$(resolve "$1"); seg=${2:-__TEXT}; sec=${3:-__const}
[ -n "$1" ] || { echo "usage: $(basename "$0") <target> [seg] [sec]" >&2; exit 2; }
echo "# section $seg,$sec of $bin ($arch)"
otool -v -arch "$arch" -s "$seg" "$sec" "$bin" 2>/dev/null
