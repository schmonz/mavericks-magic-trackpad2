#!/bin/sh
# Stop any running instance and unload our kexts (current + legacy ids). Remove a
# stale kext from /Library/Extensions (older layout; it can't load there anyway
# due to signing).
launchctl unload /Library/LaunchDaemons/com.schmonz.voodooinputmavericks.plist 2>/dev/null || true
launchctl unload /Library/LaunchDaemons/com.schmonz.voodooinputmavericks.linkstated.plist 2>/dev/null || true
# The link-state daemon was renamed twice: mt2_usb_bt_handoff (label .usbbthandoff) -> mt2_bluetooth_linkstated
# (.bluetoothlinkstated) -> mt2_linkstated (.linkstated). Purge BOTH superseded labels + their binaries so
# neither lingers and tries to load a removed binary at the next boot.
for lbl in bluetoothlinkstated usbbthandoff; do
    launchctl unload "/Library/LaunchDaemons/com.schmonz.voodooinputmavericks.$lbl.plist" 2>/dev/null || true
    rm -f "/Library/LaunchDaemons/com.schmonz.voodooinputmavericks.$lbl.plist" 2>/dev/null || true
done
rm -f /usr/local/libexec/mt2_bluetooth_linkstated /usr/local/libexec/mt2_usb_bt_handoff 2>/dev/null || true
# Legacy daemon labels from pre-rename installs (product was mt2d / MavericksVoodooInputHost).
launchctl unload /Library/LaunchDaemons/com.schmonz.mt2d.plist 2>/dev/null || true
launchctl unload /Library/LaunchDaemons/com.schmonz.mt2usbbthandoff.plist 2>/dev/null || true
kextunload -b com.schmonz.VoodooInputMavericks 2>/dev/null || true
kextunload -b com.schmonz.MavericksVoodooInputHost 2>/dev/null || true   # legacy kext id from pre-rename installs
kextunload -b com.schmonz.MT2USBClaim 2>/dev/null || true
kextunload -b com.schmonz.MT2Claim 2>/dev/null || true   # legacy id from pre-rename installs
rm -rf /Library/Extensions/MT2USBClaim.kext /Library/Extensions/MT2Claim.kext 2>/dev/null || true
# Both transports now run in-kernel inside VoodooInputMavericks: the USB-claim + legacy claim
# kexts and the userspace feeder are retired. Remove them from the loose load dir so
# a re-install over an older layout doesn't leave them behind.
rm -rf /usr/local/lib/voodooinputmavericks/MT2USBClaim.kext /usr/local/lib/voodooinputmavericks/MT2Claim.kext 2>/dev/null || true
rm -f /usr/local/sbin/mt2_gesture_feed 2>/dev/null || true
# Remove the retired synthesis daemon + prior product layouts (pre-rename: mt2d / mt2d-run,
# and the legacy /usr/local/bin location) so a re-install never leaves stale binaries behind.
rm -f /usr/local/bin/mt2d /usr/local/bin/mt2_reenumerate /usr/local/bin/mt2d-run 2>/dev/null || true
rm -f /usr/local/sbin/mt2d /usr/local/sbin/mt2d-run 2>/dev/null || true
rm -rf /usr/local/lib/mt2d 2>/dev/null || true
# Retire the standalone-osax prefpane loader (the pane companion now ships ONLY as a SIMBL plugin).
# The single-load arbitration that let the osax + SIMBL payloads coexist without double-swizzling is
# gone, so a stale osax MUST NOT be left able to co-load into System Preferences. Unload + remove its
# launch-watcher LaunchAgent and the osax bundle + watcher binary. Best-effort (they may be absent).
CONSOLE_USER=$(stat -f%Su /dev/console 2>/dev/null)
if [ -n "$CONSOLE_USER" ] && [ "$CONSOLE_USER" != "root" ]; then
    sudo -u "$CONSOLE_USER" launchctl unload /Library/LaunchAgents/com.schmonz.voodooinputmavericks.panewatch.plist 2>/dev/null || true
fi
rm -f /Library/LaunchAgents/com.schmonz.voodooinputmavericks.panewatch.plist 2>/dev/null || true
rm -rf /Library/ScriptingAdditions/VoodooInputMavericksPane.osax 2>/dev/null || true
rm -f /usr/local/libexec/voodooinputmavericks_pane_watch 2>/dev/null || true
# Same hazard for the SIMBL delivery: before the rename the pane bundle was MT2PaneRefresh.bundle. With
# the single-load guard gone, a stale pre-rename bundle would co-load alongside the new
# VoodooInputMavericksPane.bundle and DOUBLE-SWIZZLE the pane (broken UI / wrong icon). Purge the old name.
rm -rf "/Library/Application Support/SIMBL/Plugins/MT2PaneRefresh.bundle" 2>/dev/null || true
exit 0
