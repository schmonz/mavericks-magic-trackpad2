#!/bin/sh
# Stop any running instance and unload our kexts (current + legacy ids). Remove a
# stale kext from /Library/Extensions (older layout; it can't load there anyway
# due to signing).
launchctl unload /Library/LaunchDaemons/com.schmonz.voodooinputmavericks.plist 2>/dev/null || true
launchctl unload /Library/LaunchDaemons/com.schmonz.voodooinputmavericks.usbbthandoff.plist 2>/dev/null || true
# Legacy daemon labels from pre-rename installs (product was mt2d / MavericksVoodooInputHost).
launchctl unload /Library/LaunchDaemons/com.schmonz.mt2d.plist 2>/dev/null || true
launchctl unload /Library/LaunchDaemons/com.schmonz.mt2usbbthandoff.plist 2>/dev/null || true
kextunload -b com.schmonz.VoodooInputMavericks 2>/dev/null || true
kextunload -b com.schmonz.MavericksVoodooInputHost 2>/dev/null || true   # legacy kext id from pre-rename installs
kextunload -b com.schmonz.MT2USBClaim 2>/dev/null || true
kextunload -b com.schmonz.MT2Claim 2>/dev/null || true   # legacy id from pre-rename installs
rm -rf /Library/Extensions/MT2USBClaim.kext /Library/Extensions/MT2Claim.kext 2>/dev/null || true
# Both transports now run in-kernel inside VoodooInputMavericks: the USB-claim + legacy claim
# kexts and the userspace feeder are retired. Remove them from the loose load dir so
# a re-install over an older layout doesn't leave them behind.
rm -rf /usr/local/lib/voodooinputmavericks/MT2USBClaim.kext /usr/local/lib/voodooinputmavericks/MT2Claim.kext 2>/dev/null || true
rm -f /usr/local/sbin/mt2_gesture_feed 2>/dev/null || true
# Remove the retired synthesis daemon + prior product layouts (pre-rename: mt2d / mt2d-run,
# and the legacy /usr/local/bin location) so a re-install never leaves stale binaries behind.
rm -f /usr/local/bin/mt2d /usr/local/bin/mt2_reenumerate /usr/local/bin/mt2d-run 2>/dev/null || true
rm -f /usr/local/sbin/mt2d /usr/local/sbin/mt2d-run 2>/dev/null || true
rm -rf /usr/local/lib/mt2d 2>/dev/null || true
exit 0
