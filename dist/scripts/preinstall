#!/bin/sh
# Stop any running instance and unload our kexts (current + legacy ids). Remove a
# stale kext from /Library/Extensions (older layout; it can't load there anyway
# due to signing).
launchctl unload /Library/LaunchDaemons/dev.modernmavericks.voodooinputmavericks.plist 2>/dev/null || true
launchctl unload /Library/LaunchDaemons/dev.modernmavericks.voodooinputmavericks.linkstated.plist 2>/dev/null || true
# The reverse-DNS prefix moved com.schmonz -> dev.modernmavericks; the old plists are not overwritten
# by the new payload, so unload AND remove them or a duplicate label runs the same binaries.
for old in voodooinputmavericks voodooinputmavericks.linkstated; do
    launchctl unload "/Library/LaunchDaemons/com.schmonz.$old.plist" 2>/dev/null || true
    rm -f "/Library/LaunchDaemons/com.schmonz.$old.plist" 2>/dev/null || true
done
# Same for the per-user agents (they stay loaded in the GUI session until logout; removing the
# plists is what stops them coming back). Covers the intermediate com.schmonz.voodooinputmavericks.*
# names AND v0.4.5's com.schmonz.mt2updatecheck / com.schmonz.mt2panewatch (their binaries are purged
# below with /usr/local/lib/mt2d, so the removed plists can't relaunch anything).
rm -f /Library/LaunchAgents/com.schmonz.voodooinputmavericks.session.plist \
      /Library/LaunchAgents/com.schmonz.voodooinputmavericks.updatecheck.plist \
      /Library/LaunchAgents/com.schmonz.mt2updatecheck.plist \
      /Library/LaunchAgents/com.schmonz.mt2panewatch.plist 2>/dev/null || true
# The link-state daemon was renamed twice: mt2_usb_bt_handoff (label .usbbthandoff) -> mt2_bluetooth_linkstated
# (.bluetoothlinkstated) -> mt2_linkstated (.linkstated). Purge BOTH superseded labels + their binaries so
# neither lingers and tries to load a removed binary at the next boot.
for lbl in bluetoothlinkstated usbbthandoff; do
    launchctl unload "/Library/LaunchDaemons/com.schmonz.voodooinputmavericks.$lbl.plist" 2>/dev/null || true
    rm -f "/Library/LaunchDaemons/com.schmonz.voodooinputmavericks.$lbl.plist" 2>/dev/null || true
done
rm -f /usr/local/libexec/mt2_bluetooth_linkstated /usr/local/libexec/mt2_usb_bt_handoff 2>/dev/null || true
# Legacy daemon labels from pre-rename installs (product was mt2d / MavericksVoodooInputHost). Unload
# AND remove the plists -- unload alone leaves them in /Library/LaunchDaemons to relaunch a removed
# binary at the next boot.
launchctl unload /Library/LaunchDaemons/com.schmonz.mt2d.plist 2>/dev/null || true
rm -f /Library/LaunchDaemons/com.schmonz.mt2d.plist 2>/dev/null || true
launchctl unload /Library/LaunchDaemons/com.schmonz.mt2usbbthandoff.plist 2>/dev/null || true
rm -f /Library/LaunchDaemons/com.schmonz.mt2usbbthandoff.plist 2>/dev/null || true
# NB: we deliberately do NOT kextunload a running gesture kext here. A kext driving the live MT2 can't be
# unloaded -- its terminal holds a synthetic IOHIDDevice the system HID stack retains, so kextunload does a
# PARTIAL teardown (kills the reader -> trackpad goes dead) and then FAILS on the retained terminal, and a
# same-id new kext can't load over the stuck image => dead until reboot. Instead we leave the running kext
# driving the trackpad; the new one loads cleanly at the next boot (nothing resident then), and the
# postinstall tells the user to restart. The old loaders/plists/binaries are still removed (above + below),
# so nothing re-loads the old kext at that boot. This matches upstream VoodooInput and every macOS kext:
# stage now, apply at reboot. (kextunload'ing a busy driver here is what left a user dead-until-reboot.)
rm -rf /Library/Extensions/MT2USBClaim.kext /Library/Extensions/MT2Claim.kext 2>/dev/null || true
# Both transports now run in-kernel inside VoodooInputMavericks: the USB-claim + legacy claim
# kexts and the userspace feeder are retired. Remove them from the loose load dir so
# a re-install over an older layout doesn't leave them behind.
rm -rf /usr/local/lib/voodooinputmavericks/MT2USBClaim.kext /usr/local/lib/voodooinputmavericks/MT2Claim.kext 2>/dev/null || true
rm -f /usr/local/sbin/mt2_gesture_feed 2>/dev/null || true
# The updater .app moved out of the kext's dir to /Library/Application Support/ModernMavericks (and
# lost its Mavericks prefix). Nothing overwrites the old copy, and a stale one there would keep
# answering the prefpane's "check for updates" with an outdated feed. Purge both old names.
rm -rf /usr/local/lib/voodooinputmavericks/MavericksTrackpad2Updater.app \
       /usr/local/lib/voodooinputmavericks/Trackpad2Updater.app 2>/dev/null || true
# Remove the retired synthesis daemon + prior product layouts (pre-rename: mt2d / mt2d-run,
# and the legacy /usr/local/bin location) so a re-install never leaves stale binaries behind.
rm -f /usr/local/bin/mt2d /usr/local/bin/mt2_reenumerate /usr/local/bin/mt2d-run 2>/dev/null || true
rm -f /usr/local/sbin/mt2d /usr/local/sbin/mt2d-run 2>/dev/null || true
rm -rf /usr/local/lib/mt2d /usr/local/share/mt2d 2>/dev/null || true
# Retire the standalone-osax prefpane loader (the pane companion now ships ONLY as a SIMBL plugin).
# The single-load arbitration that let the osax + SIMBL payloads coexist without double-swizzling is
# gone, so a stale osax MUST NOT be left able to co-load into System Preferences. Unload + remove its
# launch-watcher LaunchAgent and the osax bundle + watcher binary. Best-effort (they may be absent).
CONSOLE_USER=$(stat -f%Su /dev/console 2>/dev/null)
if [ -n "$CONSOLE_USER" ] && [ "$CONSOLE_USER" != "root" ]; then
    sudo -u "$CONSOLE_USER" launchctl unload /Library/LaunchAgents/com.schmonz.voodooinputmavericks.panewatch.plist 2>/dev/null || true
fi
rm -f /Library/LaunchAgents/com.schmonz.voodooinputmavericks.panewatch.plist 2>/dev/null || true
# Cover BOTH the intermediate dev-identity osax (VoodooInputMavericksPane.osax / voodooinputmavericks_pane_watch)
# AND genuine v0.4.5's ORIGINAL name (MT2PaneRefresh.osax / mt2_pane_watch). v0.4.5 shipped the osax under the
# pre-rename name, so purging only the new name (the 2026-07-24 bug) left MT2PaneRefresh.osax co-loading a
# stale second About pane into System Preferences alongside the SIMBL pane.
rm -rf /Library/ScriptingAdditions/VoodooInputMavericksPane.osax \
       /Library/ScriptingAdditions/MT2PaneRefresh.osax 2>/dev/null || true
rm -f /usr/local/libexec/voodooinputmavericks_pane_watch /usr/local/libexec/mt2_pane_watch 2>/dev/null || true
# Same hazard for the SIMBL delivery: before the rename the pane bundle was MT2PaneRefresh.bundle. With
# the single-load guard gone, a stale pre-rename bundle would co-load alongside the new
# VoodooInputMavericksPane.bundle and DOUBLE-SWIZZLE the pane (broken UI / wrong icon). Purge the old name.
rm -rf "/Library/Application Support/SIMBL/Plugins/MT2PaneRefresh.bundle" 2>/dev/null || true
exit 0
