#!/bin/sh
# Activate: fix kext ownership (kextload requires root:wheel), reset the boot
# sentinel to ok (a fresh install should attempt full-gesture mode), and
# start the daemon. The launchd wrapper (mt2d-run) loads the one kext from
# /usr/local and re-enumerates the device so the in-kernel readers win their
# matches. No /Library/Extensions, no kextcache: the unsigned kext only loads
# from a loose path.
set -e

GESTURE=/usr/local/lib/mt2d/MT2Gesture.kext
PLIST=/Library/LaunchDaemons/com.schmonz.mt2d.plist
STATE=/var/db/mt2d-boot.state

chown -R root:wheel "$GESTURE"
chmod -R 755 "$GESTURE"
chmod +x /usr/local/sbin/mt2d-run

mkdir -p /var/db
echo ok > "$STATE"

launchctl unload "$PLIST" 2>/dev/null || true
launchctl load -w "$PLIST"

# Prefpane live-refresh watcher (per-user LaunchAgent). It auto-loads at the next login;
# also try to load it into the CURRENT GUI session so the feature works without a logout.
# Best-effort; never fail the install on it. We do NOT touch SIMBL — users keep SIMBL for
# unrelated plugins, and we ship no SIMBL plugin.
AGENT=/Library/LaunchAgents/com.schmonz.mt2panewatch.plist
chmod +x /usr/local/libexec/mt2_pane_watch 2>/dev/null || true
CONSOLE_USER=$(stat -f%Su /dev/console 2>/dev/null)
if [ -n "$CONSOLE_USER" ] && [ "$CONSOLE_USER" != "root" ]; then
    sudo -u "$CONSOLE_USER" launchctl unload "$AGENT" 2>/dev/null || true
    sudo -u "$CONSOLE_USER" launchctl load -w "$AGENT" 2>/dev/null || true
fi

exit 0
