#!/bin/sh
# Launchd boot wrapper: bring up full-gesture MT2 support, with a minimal
# anti-brick-loop guard.
#
# The single unsigned kext loads from this loose path (kext-dev-mode permits
# unsigned loads outside /Library/Extensions); it is NEVER placed in /Library/
# Extensions or the boot caches, so the kernel always boots clean. MT2Gesture
# matches IOResources; if loading it ever panics the machine, the guard below
# stops re-loading it on the next boot so we never get a boot-crash loop.
#
# Both transports (Bluetooth L2CAP + cabled USB) now run in-kernel inside
# MT2Gesture: loading the kext is enough — its reader personalities bind the
# device directly. There is no userspace feeder.
#
# Sentinel /var/db/mt2d-boot.state:
#   ok / missing -> load MT2Gesture (full gestures).
#   trying       -> a prior boot started full mode but never confirmed healthy
#                   (likely an MT2Gesture load panic); SKIP loading MT2Gesture
#                   until `mt2d-run --reset`. Use another pointing device meanwhile.

STATE_FILE="${MT2D_STATE_FILE:-/var/db/mt2d-boot.state}"
KEXT_DIR="${MT2D_KEXT_DIR:-/usr/local/lib/mt2d}"
SBIN="${MT2D_SBIN:-/usr/local/sbin}"
HEALTHY_DELAY="${MT2D_HEALTHY_DELAY:-20}"

log() { echo "[mt2d-run $(date '+%Y-%m-%d %H:%M:%S')] $*"; }

# --reset re-enables full mode after the guard tripped.
if [ "${1:-}" = "--reset" ]; then
    mkdir -p "$(dirname "$STATE_FILE")" 2>/dev/null || true
    echo ok > "$STATE_FILE"
    log "sentinel reset to ok; full mode will be attempted on next start"
    exit 0
fi

STATE="$(cat "$STATE_FILE" 2>/dev/null || echo ok)"

if [ "$STATE" = "trying" ]; then
    # Prior boot started full mode but never confirmed healthy -> likely a panic
    # loading MT2Gesture. Do NOT reload it; avoid a boot-crash loop.
    log "prior boot did not confirm healthy; NOT loading MT2Gesture (run 'mt2d-run --reset' to retry). Use another pointing device."
    [ "${MT2D_DRYRUN:-0}" = "1" ] && { echo "MODE=skip"; echo "STATE=$(cat "$STATE_FILE" 2>/dev/null)"; }
    exit 0
fi

echo trying > "$STATE_FILE" 2>/dev/null || true

# Dry-run: decide + record state only, no kextload (used by the unit test).
if [ "${MT2D_DRYRUN:-0}" = "1" ]; then
    echo "MODE=full"
    echo "STATE=$(cat "$STATE_FILE" 2>/dev/null)"
    exit 0
fi

log "attempting full-gesture mode"

# Load the one gesture kext (the IOResources-matching one the guard covers). Its
# BT + USB reader personalities bind the device on their own.
kextload "$KEXT_DIR/MT2Gesture.kext" 2>/dev/null || true

# Conditional re-enumerate. Let IOKit matching settle, then check whether our USB
# reader won interface 1. At cold boot the cabled MT2 is claimed by IOUSBHIDDriver
# before this kext loads, and kextload does NOT preempt an already-matched nub, so we
# force a re-enumeration to re-run matching (our 500000 probe score then wins). Only
# when needed:
#   USB reader bound (won on load)        -> skip, no disruption
#   USB reader not bound, USB MT2 present  -> re-enumerate to reclaim interface 1
#   USB reader not bound, no USB MT2       -> mt2_reenumerate exits nonzero (no device,
#                                             e.g. Bluetooth-only boot) -> nothing to do
sleep 5
if [ "$(ioclasscount com_schmonz_MT2USBReader 2>/dev/null | awk '{print $NF}')" = "0" ]; then
    if "$SBIN/mt2_reenumerate" >/dev/null 2>&1; then
        log "USB reader lost interface 1 on load; re-enumerated to reclaim it"
    else
        log "USB reader not bound and no USB MT2 present (Bluetooth-only boot); no re-enumerate needed"
    fi
else
    log "USB reader won interface 1 on load; skipping re-enumerate"
fi

# Anti-brick-loop gate, INLINE (no background subshell, which doesn't survive in
# the launchd no-TTY context): if MT2Gesture is instantiated after the settling
# window, the load did not panic -> mark ok so the next boot tries full mode
# again. With no long-lived child, the wrapper then exits and launchd lets it
# stay exited (KeepAlive=false); the kext keeps running in-kernel.
sleep "$HEALTHY_DELAY"
cnt="$(ioclasscount com_schmonz_MT2Gesture 2>/dev/null | awk '{print $NF}')"
# Record which transport reader actually bound. The nub (cnt) is IOResources-matched
# so it loads whenever the kext loads — it can NOT tell us whether BT or USB won its
# device match. Logging the reader counts leaves evidence in /var/log/mt2d.log of the
# boot-time match race (esp. BT, which has no mt2_reenumerate fallback): BT>0 means
# MT2BTReader bound the L2CAP channels; USB>0 means MT2USBReader bound interface 1.
btn="$(ioclasscount com_schmonz_MT2BTReader 2>/dev/null | awk '{print $NF}')"
usbn="$(ioclasscount com_schmonz_MT2USBReader 2>/dev/null | awk '{print $NF}')"
log "transport readers bound: BT=$btn USB=$usbn (gesture nub=$cnt)"
if [ -n "$cnt" ] && [ "$cnt" != "0" ]; then
    echo ok > "$STATE_FILE" 2>/dev/null || true
    log "full-gesture mode confirmed healthy"
fi
