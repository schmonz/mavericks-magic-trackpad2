#!/bin/sh
# Launchd boot wrapper: bring up full-gesture MT2 support, with a minimal
# anti-brick-loop guard.
#
# The single unsigned kext loads from this loose path: on 10.9, unsigned kexts
# load from outside /Library/Extensions; it is NEVER placed in /Library/
# Extensions or the boot caches, so the kernel always boots clean. VoodooInputMavericks
# matches IOResources; if loading it ever panics the machine, the guard below
# stops re-loading it on the next boot so we never get a boot-crash loop.
#
# Both transports (Bluetooth L2CAP + cabled USB) now run in-kernel inside
# VoodooInputMavericks: loading the kext is enough — its reader personalities bind the
# device directly. There is no userspace feeder.
#
# Sentinel /var/db/voodooinputmavericks-boot.state:
#   ok / missing -> load VoodooInputMavericks (full gestures).
#   trying       -> a prior boot started full mode but never confirmed healthy
#                   (likely an VoodooInputMavericks load panic); SKIP loading VoodooInputMavericks
#                   until `voodooinputmavericks-run --reset`. Use another pointing device meanwhile.

STATE_FILE="${MT2D_STATE_FILE:-/var/db/voodooinputmavericks-boot.state}"
KEXT_DIR="${MT2D_KEXT_DIR:-/usr/local/lib/voodooinputmavericks}"
SBIN="${MT2D_SBIN:-/usr/local/sbin}"
HEALTHY_DELAY="${MT2D_HEALTHY_DELAY:-20}"
# Overridable so the recovery loop is unit-testable with mocks (see tests/test_voodooinputmavericks_run.sh).
IOCLASSCOUNT="${MT2D_IOCLASSCOUNT:-ioclasscount}"
KEXTLOAD="${MT2D_KEXTLOAD:-kextload}"
KEXTUNLOAD="${MT2D_KEXTUNLOAD:-kextunload}"
RECOVER_TRIES="${MT2D_RECOVER_TRIES:-3}"
# Baseband bounce (close->open) that forces a connected BT MT2 to re-open BOTH L2CAP channels so our
# reader wins them (BT=2). Overridable so the unit test can stub it. Runs at the session-takeover, where
# our reader otherwise binds half-open (BT=1) evicting Apple's generic HID mid-connection.
BOUNCE="${MT2D_BOUNCE:-/usr/local/libexec/mt2_linkstated --bounce-once}"
# hidd kick (USB gesture-open). Our USB AMD appears into an already-running hidd that never opens its
# multitouch frames UserClient, so scroll/swipe/tap are dead (cursor + physical/2-finger click still work
# via the kernel AppleMultitouchHIDEventDriver — which is why it looks like "gestures only"). A fresh hidd
# enumerates the present device and opens the client. Proven 2026-07-20: `killall hidd` flips
# AppleMultitouchDeviceUserClient 0->1 and gestures engage on USB. This is the USB analog of the BT baseband
# bounce (BT reconnect re-triggers hidd; USB never had an equivalent). Overridable so the unit test stubs it.
# See docs/mt-stack/open-questions.md "CRACKED: USB gestures ... stale hidd, not transport".
HIDD_KICK="${MT2D_HIDD_KICK:-killall hidd}"

log() { echo "[voodooinputmavericks-run $(date '+%Y-%m-%d %H:%M:%S')] $*"; }

# recover_full: on a half-open attach (BT<2) the BT MT2 came up offering only the CONTROL channel
# (PSM 17); the INTERRUPT channel (PSM 19) is device-initiated and won't re-open on its own, so our
# reader is stuck data-less. A baseband BOUNCE (close->open) makes the device re-offer BOTH channels so
# our (still-loaded) reader binds them -> BT=2. PROVEN reliable warm 2026-07-21 — a plain disconnect
# reconnects full every time — whereas the OLD unload/reload could not force PSM 19 and reliably failed
# the cold-boot takeover. Retry: the HEALTHY_DELAY between tries rides out a still-cold-starting BT stack
# (the first bounce can land before blued/the controller are ready). On exhaustion, unload so Apple's
# generic HID still gives at least a basic cursor (never no-cursor).
recover_full() {
    i=1
    while [ "$i" -le "$RECOVER_TRIES" ]; do
        log "recovery attempt $i/$RECOVER_TRIES: bounce BT (close->open) to re-offer both L2CAP channels"
        $BOUNCE >/dev/null 2>&1 || true
        sleep "$HEALTHY_DELAY"
        btn="$("$IOCLASSCOUNT" com_schmonz_MT2BTReader 2>/dev/null | awk '{print $NF}')"
        usbn="$("$IOCLASSCOUNT" com_schmonz_MT2USBReader 2>/dev/null | awk '{print $NF}')"
        cnt="$("$IOCLASSCOUNT" com_schmonz_MavericksVoodooInputHost 2>/dev/null | awk '{print $NF}')"
        if [ "$("$0" --health-verdict "$btn" "$usbn" "$cnt")" = "healthy" ]; then
            echo ok > "$STATE_FILE" 2>/dev/null || true
            log "recovery succeeded on attempt $i: BT=$btn USB=$usbn nub=$cnt — full-gesture healthy"
            return 0
        fi
        i=$((i+1))
    done
    "$KEXTUNLOAD" -b com.schmonz.VoodooInputMavericks 2>/dev/null || true
    log "RECOVERY EXHAUSTED after $RECOVER_TRIES tries: leaving generic HID (cursor only, no gestures)"
    return 1
}

# --reset re-enables full mode after the guard tripped.
if [ "${1:-}" = "--reset" ]; then
    mkdir -p "$(dirname "$STATE_FILE")" 2>/dev/null || true
    echo ok > "$STATE_FILE"
    log "sentinel reset to ok; full mode will be attempted on next start"
    exit 0
fi

# --health-verdict <bt> <usb> <nub>: print "healthy" or "incomplete" for the given reader counts.
# Healthy = the gesture nub loaded AND a transport is FULLY bound: Bluetooth needs BOTH L2CAP
# channels (BT>=2 = control+interrupt); USB needs its one interface (USB>=1). BT=1 is a half-open
# attach (interrupt channel missing) and is NOT healthy. Pure function of its args -> unit-testable,
# and (being a subcommand that exits here) it never reaches the kextload main flow below.
if [ "${1:-}" = "--health-verdict" ]; then
    bt="${2:-0}"; usb="${3:-0}"; nub="${4:-0}"
    if [ "$nub" != "0" ] && { [ "$bt" -ge 2 ] || [ "$usb" -ge 1 ]; }; then
        echo healthy
    else
        echo incomplete
    fi
    exit 0
fi

# --recover: run the half-open recovery loop in isolation (testable with mocked kext/count commands).
if [ "${1:-}" = "--recover" ]; then
    recover_full
    exit $?
fi

# --- Session guard -------------------------------------------------------------------------------
# Only take the MT2 over (load our kext) once a GUI user is actually logged in. At the login window
# /dev/console is owned by root; a real user owns it only after login. Pre-session we deliberately do
# NOT load, leaving the device to Apple's generic HID -> an instant basic cursor at the login screen
# (docs/superpowers login-screen-basic-hid design). This daemon runs BOTH at boot (RunAtLoad -> a
# guarded no-op) and at session start (a WatchPaths trigger the per-user LaunchAgent touches).
# MT2D_STAT_CONSOLE is overridable for the unit test; MT2D_FORCE_LOAD=1 bypasses the guard.
STAT_CONSOLE="${MT2D_STAT_CONSOLE:-stat -f%Su /dev/console}"
CONSOLE_USER="$($STAT_CONSOLE 2>/dev/null || echo root)"
if [ "${MT2D_FORCE_LOAD:-0}" != "1" ] && { [ -z "$CONSOLE_USER" ] || [ "$CONSOLE_USER" = "root" ]; }; then
    log "login screen (console user=${CONSOLE_USER:-none}): leaving the MT2 to Apple's generic HID; not loading VoodooInputMavericks"
    [ "${MT2D_DRYRUN:-0}" = "1" ] && echo "MODE=skip-nosession"
    exit 0
fi

STATE="$(cat "$STATE_FILE" 2>/dev/null || echo ok)"

if [ "$STATE" = "trying" ]; then
    # Prior boot started full mode but never confirmed healthy -> likely a panic
    # loading VoodooInputMavericks. Do NOT reload it; avoid a boot-crash loop.
    log "prior boot did not confirm healthy; NOT loading VoodooInputMavericks (run 'voodooinputmavericks-run --reset' to retry). Use another pointing device."
    [ "${MT2D_DRYRUN:-0}" = "1" ] && { echo "MODE=skip"; echo "STATE=$(cat "$STATE_FILE" 2>/dev/null)"; }
    exit 0
fi

echo trying > "$STATE_FILE" 2>/dev/null || true

# Dry-run: decide + record state only, no kextload (used by the unit test).
if [ "${MT2D_DRYRUN:-0}" = "1" ]; then
    echo "MODE=full"
    echo "STATE=$(cat "$STATE_FILE" 2>/dev/null)"
    exit 0
fi

log "attempting full-gesture mode"

# The genuine BT/USB paths manual-start Apple's own drivers — BNBTrackpadDevice (from
# AppleBluetoothMultitouch.kext) and AppleUSBMultitouchDriver (from AppleUSBMultitouch.kext) — via
# allocClassWithName. Those kexts load on demand and are NOT guaranteed present at boot, so load them
# first (best-effort) or the readers get a NULL class and the genuine path is dead with no fallback.
# Their on-disk personalities do NOT steal our device (USB lacks PID 613; BT loses the L2CAP channel
# probe to our reader), so loading them is safe — they only register the classes we manual-start.
# (Why script-load and not OSBundleLibraries: AppleBluetoothMultitouch has no OSBundleCompatibleVersion
# so it can't be a library dep; we keep one uniform, soft mechanism. See docs/mt-stack/decisions.md.)
"$KEXTLOAD" /System/Library/Extensions/AppleUSBMultitouch.kext 2>/dev/null || true
"$KEXTLOAD" /System/Library/Extensions/AppleBluetoothMultitouch.kext 2>/dev/null || true

# Load the one gesture kext (the IOResources-matching one the guard covers). Its
# BT + USB reader personalities bind the device on their own.
"$KEXTLOAD" "$KEXT_DIR/VoodooInputMavericks.kext" 2>/dev/null || true

# NOTE: kext diagnostics (debug.mt2_log) default OFF; the screensaver-capture boot-enable was removed
# once that investigation concluded (not our bug). Enable on demand: `sudo sysctl debug.mt2_log=1`
# (milestones / BT conn-trace) or `=2` (verbose per-frame, both transports). See mt2_diag / mt2_log.

# NOTE: we deliberately do NOT touch the device's name here. The MT2 stores its own persistent name
# (HID Feature report 0x55) and 10.9 surfaces it fine; the name is written ONLY on an explicit user
# Rename in the Bluetooth pane (the injected osax mirrors that onto the device — see docs/mt-stack
# "Rename routing + the mirror"). Nothing writes the name unrequested.

# Determine transport, THEN do only that transport's takeover work. The MT2 drives ONE transport at a
# time (cabling USB drops BT), so a USB boot must NOT do BT work and vice versa.
#
# Conditional re-enumerate. Let IOKit matching settle, then check whether our USB reader won interface
# 1. At cold boot the cabled MT2 is claimed by IOUSBHIDDriver before this kext loads, and kextload does
# NOT preempt an already-matched nub, so we force a re-enumeration to re-run matching (our 500000 probe
# score then wins). mt2_reenumerate succeeds iff a USB MT2 is present, so it doubles as our "is this a
# USB boot?" probe:
#   USB reader bound (won on load)        -> on USB, skip re-enumerate
#   USB reader not bound, USB MT2 present  -> on USB, re-enumerate to reclaim interface 1
#   USB reader not bound, no USB MT2       -> NOT USB (Bluetooth-only or no device)
# Settle: wait only until our kext is actually registered, then decide — a CONDITION, not a fixed
# sleep. The nub (MavericksVoodooInputHost, IOResources-matched) instantiates as soon as kextload
# processes our personalities into the matching catalog; once it's present, the MT2USB reader
# personality is in the catalog too, so the reclaim's re-match will pick our 500000 reader. kextload is
# synchronous, so on a normal boot this passes on the first check (~0s). It only ever waits if a load
# is unexpectedly slow, and is bounded so a failed load (nub never appears) falls through to the "nub
# absent" health branch below rather than hanging. The won-vs-lost check is then immediately conclusive
# (won-on-load = reader already resident from a re-trigger -> nonzero instantly; cold boot never wins ->
# 0 -> reclaim). Replaces a fixed 5s->1s settle the timing breakdown (2026-07-21) showed was pure margin.
settle=0
while [ "$("$IOCLASSCOUNT" com_schmonz_MavericksVoodooInputHost 2>/dev/null | awk '{print $NF}')" = "0" ] \
      && [ "$settle" -lt "${MT2D_SETTLE_TRIES:-25}" ]; do
    settle=$((settle + 1)); sleep 0.2
done
on_usb=0
if [ "$("$IOCLASSCOUNT" com_schmonz_MT2USBReader 2>/dev/null | awk '{print $NF}')" != "0" ]; then
    log "USB reader won interface 1 on load; skipping re-enumerate"
    on_usb=1
elif "$SBIN/mt2_reenumerate" >/dev/null 2>&1; then
    log "USB reader lost interface 1 on load; re-enumerated to reclaim it"
    on_usb=1
else
    log "USB reader not bound and no USB MT2 present (Bluetooth-only boot); no re-enumerate needed"
fi

# BT baseband bounce — ONLY on a non-USB boot. At the BT session-load we evict Apple's generic HID
# mid-connection and our reader tends to win only the CONTROL channel (BT=1, half-open — the device-
# initiated interrupt channel PSM 19 doesn't re-open for us); a bounce (close->open) makes the device
# re-open BOTH channels so our reader binds both (BT=2). Proven on-device 2026-07-19.
#
# SKIP it on USB: the MT2 is single-transport, so its BT link is DOWN while cabled — the bounce's
# openConnection just blocks ~10.5s timing out against a device that can't answer over BT (measured
# 2026-07-21), adding ~10.5s of dead time to every USB boot for zero benefit. (The old code ran this
# unconditionally and mislabeled it a "no-op for USB".)
if [ "$on_usb" = "0" ]; then
    $BOUNCE >/dev/null 2>&1 || true
else
    log "on USB -> skipping BT bounce (single-transport; BT link is down while cabled)"
fi

# Anti-brick-loop gate, INLINE (no background subshell, which doesn't survive in
# the launchd no-TTY context). The brick-guard protects against LOAD-TIME PANICS
# only: a panic loading VoodooInputMavericks reboots the machine before we reach this point,
# leaving the sentinel 'trying' so the next boot skips. Surviving the settle window
# is therefore the whole signal — so mark 'ok' UNCONDITIONALLY here, decoupled from
# whether a transport bound. (Earlier this gated 'ok' on a bound transport, which
# false-tripped the guard on the perfectly-normal "no trackpad connected at boot"
# case — common on a desktop, esp. now that genuine is the default — leaving 'trying'
# and skip-loading the next boot. Device binding is a FUNCTIONALITY concern below,
# never a sentinel gate.)
sleep "$HEALTHY_DELAY"
cnt="$("$IOCLASSCOUNT" com_schmonz_MavericksVoodooInputHost 2>/dev/null | awk '{print $NF}')"
# Reader counts are diagnostics + the recovery trigger, not a sentinel gate. The nub
# (cnt) is IOResources-matched so it loads with the kext regardless of device; BT>0
# means MT2BTReader bound the L2CAP channels, USB>0 means MT2USBReader bound interface 1.
btn="$("$IOCLASSCOUNT" com_schmonz_MT2BTReader 2>/dev/null | awk '{print $NF}')"
usbn="$("$IOCLASSCOUNT" com_schmonz_MT2USBReader 2>/dev/null | awk '{print $NF}')"
log "transport readers bound: BT=$btn USB=$usbn (gesture nub=$cnt)"
# USB gesture-open is now owned SOLELY by mt2_linkstated, NOT the wrapper. The daemon arms its
# presence observers early in boot (measured 2026-07-21: armed 45s before the reclaim), so the USB
# re-enumeration mt2_reenumerate does above is a LIVE USB-appear to it -> it kicks hidd at appear+2s
# (kick_hidd, tools/mt2_linkstated.m), opening the AMD frames client -> gestures. The wrapper ALSO
# kicking here made TWO kills ~1s apart; the second interrupts the first hidd respawn -> a ~9s all-HID
# freeze ("cursor stuck", measured 2026-07-21). One owner = one kick = no collision. (Won-on-load boots:
# the device is present when the daemon arms, drained as an initial iterator, so the daemon does NOT
# kick — but a won-on-load boot means our reader already holds the interrupt pipe and hidd enumerated it
# at its own startup, so no kick is needed there either. If this experiment shows a won-on-load boot
# lacks gestures, restore a wrapper kick GATED to the won-on-load branch only.)
echo ok > "$STATE_FILE" 2>/dev/null || true            # survived load+settle => brick-guard satisfied
if [ "$cnt" = "0" ]; then
    log "WARNING: VoodooInputMavericks nub absent after load — kext load failed (no panic; will retry next boot)"
elif [ "$("$0" --health-verdict "$btn" "$usbn" "$cnt")" = "healthy" ]; then
    log "full-gesture mode confirmed healthy (BT=$btn USB=$usbn)"
elif [ "$btn" = "1" ]; then
    # Device present over Bluetooth but HALF-OPEN (interrupt channel missing): the
    # load-after-connect lever can upgrade BT 1->2. Best-effort; sentinel is already ok.
    log "BT half-open (BT=1, interrupt channel missing) — attempting recovery"
    recover_full || true
else
    log "kext loaded; no trackpad bound yet (BT=$btn USB=$usbn) — readers will bind on connect"
fi
