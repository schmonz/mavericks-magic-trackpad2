# editor / compiler cruft
._*
*.o
*.d
spike_bind
.idea/
.ai/

# build outputs: unit tests -> build/tests/, pkg staging -> build/, the kext bundle
build/
# CMake out-of-tree build dir (Task 1+; kept separate from the Makefile's build/)
cmake-build/
cmake-build-debug/
# CMakePresets native/cross build dirs (mavericks-shared-cmake convention)
build-native/
build-cross/
kext-gesture/MavericksVoodooInputHost.kext/
kext-gesture/*.o

# root tool binaries (compiled from tools/*.c by `make`)
/mt2d
/multitouch_listen
/sbin/

# tools/ compiled helpers (the .c sources + the `re` toolkit are tracked; these built binaries aren't)
tools/feed_probe
tools/multitouch_contacts
tools/multitouch_cursorpos
tools/multitouch_transport
tools/synth_feed
tools/synth_tap
tools/click_monitor
tools/kc_lzss
tools/kc_carve
